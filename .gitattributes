# Default: normalize text files to LF in the repo + working tree
* text=auto eol=lf

# Windows-only scripts should stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (prevent Git trying to treat them as text)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary

@inject ChatState ChatState

<div class="channels-list">
    <div class="channels-section">
        @foreach (var channel in ChatState.GetVisibleChannels())
        {
            <div class="channels-item @(IsChannelSelected(channel) ? "active" : "")" @onclick="() => SelectChannel(channel)">
                <span class="channels-item-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="4" y1="9" x2="20" y2="9"/>
                        <line x1="4" y1="15" x2="20" y2="15"/>
                        <line x1="10" y1="3" x2="8" y2="21"/>
                        <line x1="16" y1="3" x2="14" y2="21"/>
                    </svg>
                </span>
                <span class="channels-name">@channel.Name</span>
                @if (channel.Description != null)
                {
                    <span class="channels-tooltip">@channel.Description</span>
                }
            </div>
        }
    </div>

    <div class="create-channel-wrap">
        <input type="text"
               class="create-channel-input"
               placeholder="Enter channel name..."
               @bind="newChannelName"
               @onkeydown="HandleCreateChannelKeyDown" />
        <button type="button" class="create-channel-btn" @onclick="HandleCreateChannelClick">
            <span class="create-channel-btn-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
            </span>
            <span>Create Channel</span>
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        ChatState.OnChange += OnStateChanged;
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChatState.OnChange -= OnStateChanged;
    }

    private bool IsChannelSelected(ChannelDto channel) => ChatState.SelectedChannel?.Id == channel.Id;

    private void SelectChannel(ChannelDto channel)
    {
        ChatState.SelectedChannel = channel;
    }

    [Parameter]
    public EventCallback<string> OnCreateChannel { get; set; }

    private string newChannelName = string.Empty;

    private async Task HandleCreateChannelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitCreateChannel();
        }
    }

    private async Task HandleCreateChannelClick()
    {
        await SubmitCreateChannel();
    }

    private async Task SubmitCreateChannel()
    {
        var name = newChannelName?.Trim();
        if (string.IsNullOrEmpty(name)) return;

        await OnCreateChannel.InvokeAsync(name);
        newChannelName = string.Empty;
    }
}

@inject ChatState ChatState

<div class="members-list">
    @if (ChatState.SelectedChannel != null)
    {
        var channelAgents = ChatState.GetChannelAgents();

        @if (channelAgents.Count > 0)
        {
            <div class="members-section">
                <div class="members-section-header">Agents — @channelAgents.Count</div>

                @foreach (var agent in channelAgents)
                {
                    <div class="members-item" @onclick="() => MentionAgent(agent)">
                        <div class="members-avatar @GetStatusClass(agent.Status)">
                            @GetInitials(agent.Username)
                            <div class="members-status @GetStatusClass(agent.Status)"></div>
                        </div>
                        <div class="members-info">
                            <div class="members-name bot-name">@agent.Username</div>
                            @if (agent.Status != "Idle" && agent.Status != "Offline")
                            {
                                <div class="members-status-text">@agent.Status</div>
                            }
                        </div>
                        <div class="bot-badge">BOT</div>
                    </div>
                }
            </div>
        }

        <div class="members-section">
            <div class="members-section-header">Online — @GetOnlineUsersCount()</div>

            @foreach (var user in GetOnlineUsers())
            {
                <div class="members-item" @onclick="() => MentionUser(user)">
                    <div class="members-avatar online">
                        @GetInitials(user.Username)
                        <div class="members-status online"></div>
                    </div>
                    <div class="members-info">
                        <div class="members-name">@user.Username</div>
                    </div>
                </div>
            }
        </div>

        <div class="members-section">
            <div class="members-section-header">Offline — @GetOfflineUsersCount()</div>

            @foreach (var user in GetOfflineUsers())
            {
                <div class="members-item">
                    <div class="members-avatar offline">
                        @GetInitials(user.Username)
                        <div class="members-status offline"></div>
                    </div>
                    <div class="members-info">
                        <div class="members-name">@user.Username</div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-selection">
            Select a channel to see members
        </div>
    }
</div>

@code {
    private string GetInitials(string username)
    {
        if (string.IsNullOrEmpty(username)) return "?";
        var parts = username.Split(' ');
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        }
        return username.Length >= 2 ? username.Substring(0, 2).ToUpper() : username.ToUpper();
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "online" => "online",
        "thinking" => "online",
        "idle" => "idle",
        "dnd" => "dnd",
        "running" => "dnd",
        _ => "offline"
    };

    private List<UserDto> GetOnlineUsers() => ChatState.GetOnlineUsers().Where(u => u.IsOnline).ToList();

    private List<UserDto> GetOfflineUsers() => ChatState.GetOnlineUsers().Where(u => !u.IsOnline).ToList();

    private int GetOnlineUsersCount() => GetOnlineUsers().Count;

    private int GetOfflineUsersCount() => GetOfflineUsers().Count;

    private void MentionAgent(AgentDto agent)
    {
        // TODO: Implement mention functionality
    }

    private void MentionUser(UserDto user)
    {
        // TODO: Implement mention functionality
    }
}

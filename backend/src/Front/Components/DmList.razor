@inject AppState AppState
@implements IDisposable

<div class="channels-list">
    <div class="channels-section">
        @foreach (var dm in AppState.Dms)
        {
            <div class="channels-item @(IsDmSelected(dm) ? "active" : "")" @onclick="() => SelectDm(dm)">
                @if (dm.OtherAgent != null)
                {
                    <span class="agent-icon">🤖</span>
                }
                else
                {
                    <span class="dm-icon">@GetInitials(dm.OtherUser?.Username ?? "User")</span>
                }
                <span class="dm-name">@GetDmDisplayName(dm)</span>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += OnStateChanged;
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnChange -= OnStateChanged;
    }

    private bool IsDmSelected(DmChannelDto dm) => AppState.SelectedDm?.Id == dm.Id;

    private void SelectDm(DmChannelDto dm)
    {
        AppState.SelectedDm = dm;
    }

    private string GetDmDisplayName(DmChannelDto dm)
    {
        return dm.OtherAgent?.Username ?? dm.OtherUser?.Username ?? "Unknown";
    }

    private string GetInitials(string username)
    {
        if (string.IsNullOrEmpty(username)) return "?";
        var parts = username.Split(' ');
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        }
        return username.Length >= 2 ? username.Substring(0, 2).ToUpper() : username.ToUpper();
    }
}

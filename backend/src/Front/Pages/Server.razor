@page "/server/{serverId}"

@inject ChatState ChatState
@inject ChannelService ChannelService

<MainLayout>
    <LeftSidebar>
        <Front.Layout.Components.LeftSidebar Title="Main">
            <ChannelsList />
            <UserPanel />
        </Front.Layout.Components.LeftSidebar>
    </LeftSidebar>
    <MainArea>
        <ChatArea Messages="messages"
                  CurrentUserId="ChatState.CurrentUser?.Id"
                  TypingAgents="ChatState.GetTypingAgents()"
                  ShowInput="ChatState.SelectedChannel != null"
                  Placeholder="@(ChatState.SelectedChannel != null ? $"Message #{ChatState.SelectedChannel.Name}" : "")"
                  EmptyIcon="@(ChatState.SelectedChannel != null ? "#" : "👋")"
                  EmptyTitle="@(ChatState.SelectedChannel != null ? $"Welcome to #{ChatState.SelectedChannel.Name}!" : "Select a channel")"
                  EmptySubtitle="@(ChatState.SelectedChannel != null ? $"This is the start of the #{ChatState.SelectedChannel.Name} channel." : "Pick a channel from the sidebar to start chatting.")"
                  OnSendMessage="SendChannelMessage" />
    </MainArea>
    <RightSidebar>
        <Front.Layout.Components.RightSidebar Title="Members">
            <MembersList />
        </Front.Layout.Components.RightSidebar>
    </RightSidebar>
</MainLayout>

@code {
    private List<ChatMessageDto> messages = [];
    private Guid? _loadedChannelId;

    [Parameter]
    public string? ServerId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SetServerFromRoute();
        await ChatState.LoadChannels(ChannelService);
        ChatState.OnChange += OnStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        SetServerFromRoute();
        await LoadMessagesIfNeeded();
    }

    private async void OnStateChanged()
    {
        await LoadMessagesIfNeeded();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadMessagesIfNeeded()
    {
        var channelId = ChatState.SelectedChannel?.Id;
        if (channelId.HasValue && channelId != _loadedChannelId)
        {
            _loadedChannelId = channelId;
            messages = await ChannelService.GetChannelMessagesAsync(channelId.Value);
        }
    }

    private async Task SendChannelMessage(string text)
    {
        if (ChatState.SelectedChannel == null) return;

        var newMessage = await ChannelService.PostMessageAsync(ChatState.SelectedChannel.Id, text);
        if (newMessage != null)
        {
            newMessage.IsOwnMessage = true;
            messages.Add(newMessage);
        }
    }

    private void SetServerFromRoute()
    {
        if (!string.IsNullOrEmpty(ServerId) && Guid.TryParse(ServerId, out var parsedServerId))
        {
            var server = ChatState.Servers.FirstOrDefault(s => s.Id == parsedServerId);
            if (server != null)
            {
                ChatState.SelectedServer = server;
            }
        }
    }

    public void Dispose()
    {
        ChatState.OnChange -= OnStateChanged;
    }
}

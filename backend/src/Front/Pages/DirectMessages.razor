@page "/dms"
@page "/dms/{dmId}"

@inject ChatState ChatState
@inject DmService DmService

<MainLayout>
    <LeftSidebar>
        <Front.Layout.Components.LeftSidebar Title="Direct Messages">
            <DmList />
            <UserPanel />
        </Front.Layout.Components.LeftSidebar>
    </LeftSidebar>
    <MainArea>
        <ChatArea Messages="messages"
                  CurrentUserId="ChatState.CurrentUser?.Id"
                  ShowInput="ChatState.SelectedDm != null"
                  Placeholder="@(ChatState.SelectedDm != null ? $"Message @{GetDmName()}" : "")"
                  EmptyIcon="@(ChatState.SelectedDm != null ? "💬" : "👋")"
                  EmptyTitle="@(ChatState.SelectedDm != null ? "Welcome to this conversation!" : "Select a conversation")"
                  EmptySubtitle="@(ChatState.SelectedDm != null ? "This is the start of your conversation." : "Pick a DM from the sidebar to start chatting.")"
                  OnSendMessage="SendDmMessage" />
    </MainArea>
    <RightSidebar>
        <Front.Layout.Components.RightSidebar Title="Members">
            <MembersList />
        </Front.Layout.Components.RightSidebar>
    </RightSidebar>
</MainLayout>

@code {
    private List<ChatMessageDto> messages = [];
    private Guid? _loadedDmId;

    [Parameter]
    public string? DmId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ChatState.LoadDms(DmService);
        SetDmFromRoute();
        ChatState.OnChange += OnStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        SetDmFromRoute();
        await LoadMessagesIfNeeded();
    }

    private async void OnStateChanged()
    {
        await LoadMessagesIfNeeded();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadMessagesIfNeeded()
    {
        var dmId = ChatState.SelectedDm?.Id;
        if (dmId.HasValue && dmId != _loadedDmId)
        {
            _loadedDmId = dmId;
            messages = await DmService.GetDmMessagesAsync(dmId.Value);
        }
    }

    private async Task SendDmMessage(string text)
    {
        var dm = ChatState.SelectedDm;
        if (dm == null) return;

        ChatMessageDto? newMessage = null;

        if (dm.OtherAgent != null)
            newMessage = await DmService.PostAgentDmMessageAsync(dm.OtherAgent.Id, text);
        else if (dm.OtherUser != null)
            newMessage = await DmService.PostUserDmMessageAsync(dm.OtherUser.Id, text);

        if (newMessage != null)
        {
            newMessage.IsOwnMessage = true;
            messages.Add(newMessage);
        }
    }

    private void SetDmFromRoute()
    {
        if (!string.IsNullOrEmpty(DmId) && Guid.TryParse(DmId, out var parsedDmId))
        {
            var dm = ChatState.Dms.FirstOrDefault(d => d.Id == parsedDmId);
            if (dm != null)
            {
                ChatState.SelectedDm = dm;
                return;
            }
        }

        ChatState.SelectedDm = null;
    }

    private string GetDmName()
    {
        return ChatState.SelectedDm?.OtherAgent?.Username
               ?? ChatState.SelectedDm?.OtherUser?.Username
               ?? "Unknown";
    }

    public void Dispose()
    {
        ChatState.OnChange -= OnStateChanged;
    }
}

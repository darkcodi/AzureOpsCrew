@page "/servers/{serverId}"

@inject AppState AppState
@inject ChannelService ChannelService
@inject AgentService AgentService

<MainLayout>
    <LeftSidebar>
        <Front.Layout.Components.LeftSidebar Title="Main">
            <ChannelsList />
            <UserPanel />
        </Front.Layout.Components.LeftSidebar>
    </LeftSidebar>
    <MainArea>
        <ChatArea Messages="[]"
                  ShowInput="false"
                  Placeholder=""
                  EmptyIcon="👋"
                  EmptyTitle="Select a channel"
                  EmptySubtitle="Pick a channel from the sidebar to start chatting." />
    </MainArea>
    <RightSidebar>
        <Front.Layout.Components.RightSidebar>
            <MembersList />
        </Front.Layout.Components.RightSidebar>
    </RightSidebar>
</MainLayout>

@code {
    [Parameter]
    public string? ServerId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SetServerFromRoute();
        AppState.SelectedChannel = null;
        await AppState.LoadChannels(ChannelService);
        await AppState.LoadAgents(AgentService);
    }

    protected override void OnParametersSet()
    {
        SetServerFromRoute();
    }

    private void SetServerFromRoute()
    {
        if (!string.IsNullOrEmpty(ServerId) && Guid.TryParse(ServerId, out var parsedServerId))
        {
            var server = AppState.Servers.FirstOrDefault(s => s.Id == parsedServerId);
            if (server != null)
            {
                AppState.SelectedServer = server;
            }
        }
    }
}

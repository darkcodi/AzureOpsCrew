@page "/servers/{serverId}/channels/{channelId}"

@inject AppState AppState
@inject ChannelService ChannelService
@inject AgentService AgentService
@inject NavigationManager NavigationManager

<MainLayout>
    <LeftSidebar>
        <Front.Layout.Components.LeftSidebar Title="Channels">
            <ChannelsList OnCreateChannel="HandleCreateChannel" />
            <UserPanel />
        </Front.Layout.Components.LeftSidebar>
    </LeftSidebar>
    <MainArea>
        <ChatArea Messages="messages"
                  CurrentUserId="AppState.CurrentUser?.Id"
                  TypingAgents="[]"
                  ShowInput="AppState.SelectedChannel != null"
                  Placeholder="@(AppState.SelectedChannel != null ? $"Message #{AppState.SelectedChannel.Name}" : "")"
                  EmptyIcon="@(AppState.SelectedChannel != null ? "#" : "👋")"
                  EmptyTitle="@(AppState.SelectedChannel != null ? $"Welcome to #{AppState.SelectedChannel.Name}!" : "Select a channel")"
                  EmptySubtitle="@(AppState.SelectedChannel != null ? $"This is the start of the #{AppState.SelectedChannel.Name} channel." : "Pick a channel from the sidebar to start chatting.")"
                  OnSendMessage="SendChannelMessage" />
    </MainArea>
    <RightSidebar>
        <Front.Layout.Components.RightSidebar>
            <MembersList />
        </Front.Layout.Components.RightSidebar>
    </RightSidebar>
</MainLayout>

@code {
    private List<ChatMessageDto> messages = [];
    private Guid? _loadedChannelId;

    [Parameter]
    public string? ServerId { get; set; }

    [Parameter]
    public string? ChannelId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await AppState.LoadChannels(ChannelService);
        await AppState.LoadAgents(AgentService);
        SetChannelAndServerFromRoute();
        AppState.OnChange += OnStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        SetChannelAndServerFromRoute();
        await LoadMessagesIfNeeded();
    }

    private async void OnStateChanged()
    {
        await LoadMessagesIfNeeded();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadMessagesIfNeeded()
    {
        var channelId = AppState.SelectedChannel?.Id;
        if (channelId.HasValue && channelId != _loadedChannelId)
        {
            _loadedChannelId = channelId;
            messages = await ChannelService.GetChannelMessagesAsync(channelId.Value);
        }
    }

    private async Task SendChannelMessage(string text)
    {
        if (AppState.SelectedChannel == null) return;

        var newMessage = await ChannelService.PostMessageAsync(AppState.SelectedChannel.Id, text);
        if (newMessage != null)
        {
            newMessage.IsOwnMessage = true;
            messages.Add(newMessage);
        }
    }

    private void SetChannelAndServerFromRoute()
    {
        // Set server from route
        if (!string.IsNullOrEmpty(ServerId) && Guid.TryParse(ServerId, out var parsedServerId))
        {
            var server = AppState.Servers.FirstOrDefault(s => s.Id == parsedServerId);
            if (server != null)
            {
                AppState.SelectedServer = server;
            }
        }

        // Set channel from route
        if (!string.IsNullOrEmpty(ChannelId) && Guid.TryParse(ChannelId, out var parsedChannelId))
        {
            var channel = AppState.Channels.FirstOrDefault(c => c.Id == parsedChannelId);
            if (channel != null)
            {
                AppState.SelectedChannel = channel;
                return;
            }
        }

        // If channel not found, keep the current selection or clear it
        if (string.IsNullOrEmpty(ChannelId))
        {
            AppState.SelectedChannel = null;
        }
    }

    private async Task HandleCreateChannel(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return;
        var created = await ChannelService.CreateChannelAsync(name.Trim(), null, []);
        if (created)
        {
            await AppState.LoadChannels(ChannelService, forceReload: true);
        }
    }

    public void Dispose()
    {
        AppState.OnChange -= OnStateChanged;
    }
}

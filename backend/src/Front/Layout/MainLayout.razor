@inherits LayoutComponentBase

<div class="discord-layout">
    <ServerStrip />
    @if (LeftSidebar != null)
    {
        @LeftSidebar
    }
    @if (MainArea != null)
    {
        @MainArea
    }
    @if (RightSidebar != null)
    {
        @RightSidebar
    }
    @Body
</div>

@code {
    [Parameter] public RenderFragment? LeftSidebar { get; set; }
    [Parameter] public RenderFragment? MainArea { get; set; }
    [Parameter] public RenderFragment? RightSidebar { get; set; }
}

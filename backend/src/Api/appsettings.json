{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "DatabaseProvider": "Sqlite",
  "Sqlite": {
    "DataSource": "Data Source=azureopscrew.db"
  },
  "SqlServer": {
    "ConnectionString": "Server=localhost;Database=AzureOpsCrew;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "KeycloakOidc": {
    "Enabled": false,
    "Authority": "",
    "ClientId": "",
    "RequireVerifiedEmail": true
  },
  "Seeding": {
    "IsEnabled": false,
    "AzureFoundrySeed": {
      "ApiEndpoint": "",
      "Key": ""
    }
  }
}

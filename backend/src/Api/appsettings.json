{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "DatabaseProvider": "Sqlite",
  "Sqlite": {
    "DataSource": "Data Source=azureopscrew.db"
  },
  "SqlServer": {
    "ConnectionString": "Server=localhost;Database=AzureOpsCrew;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "AzureOpsCrew",
    "Audience": "AzureOpsCrewFrontend",
    "SigningKey": "",
    "AccessTokenMinutes": 480
  },
  "OpenAI": {
    "ApiKey": ""
  },
  "Mcp": {
    "Azure": {
      "ServerUrl": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "TokenUrl": "",
      "Scope": "https://management.azure.com/.default"
    },
    "AzureDevOps": {
      "ServerUrl": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "TokenUrl": "",
      "Scope": "499b84ac-1321-427f-aa17-267ca6975798/.default"
    }
  },
  "Seeding": {
    "IsEnabled": false
  },
  "LongTermMemory": {
    "Type": "InMemory",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "password"
    }
  }
}
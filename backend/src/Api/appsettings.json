{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "DatabaseProvider": "SqlServer",
  "Sqlite": {
    "DataSource": "Data Source=azureopscrew.db"
  },
  "SqlServer": {
    "ConnectionString": "Server=localhost;Database=AzureOpsCrew;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AzureOpenAI": {
    "Endpoint": "https://azureopscrewglobfoundry.cognitiveservices.azure.com",
    "ApiKey": "YOUR_KEY_HERE",
    "Model": "gpt-5-2-chat"
  },
  "EnableSeeding": "false"
}

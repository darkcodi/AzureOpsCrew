{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "DatabaseProvider": "Sqlite",
  "Sqlite": {
    "DataSource": "Data Source=azureopscrew.db"
  },
  "SqlServer": {
    "ConnectionString": "Server=localhost;Database=AzureOpsCrew;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "AzureOpsCrew",
    "Audience": "AzureOpsCrewFrontend",
    "SigningKey": "",
    "AccessTokenMinutes": 480
  },
  "OpenAI": {
    "ApiKey": ""
  },
  "Mcp": {
    "Azure": {
      "ServerUrl": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "TokenUrl": "",
      "Scope": "https://management.azure.com/.default"
    },
    "AzureDevOps": {
      "ServerUrl": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "TokenUrl": "",
      "Scope": "499b84ac-1321-427f-aa17-267ca6975798/.default"
    },
    "Platform": {
      "ServerUrl": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "TokenUrl": "",
      "Scope": "https://management.azure.com/.default"
    },
    "GitOps": {
      "ServerUrl": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "TokenUrl": "",
      "Scope": "https://management.azure.com/.default"
    }
  },
  "Seeding": {
    "IsEnabled": false
  },
  "LongTermMemory": {
    "Type": "InMemory",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "password"
    }
  },
  "Orchestration": {
    "MaxRoundsPerRun": 5,
    "MaxConsecutiveNonToolTurns": 3,
    "IdleTimeoutSeconds": 45,
    "TotalTimeoutMinutes": 5,
    "ServiceRegistryPath": "../../data/service-registry.yaml",
    "ModelSettings": {
      "manager": {
        "Temperature": 0.1
      },
      "devops": {
        "Temperature": 0.05
      },
      "developer": {
        "Temperature": 0.2
      }
    }
  },
  "ExecutionEngine": {
    "MaxStepsPerRun": 50,
    "MaxStepsPerTask": 15,
    "MaxReplans": 5,
    "MaxConsecutiveNonProgressSteps": 5,
    "TaskTimeoutSeconds": 120,
    "RunTimeoutMinutes": 15,
    "MaxTaskTreeDepth": 5,
    "MaxTasksPerRun": 30,
    "MaxRetriesPerTask": 2,
    "ApprovalRequiredActions": [
      "deploy",
      "rollback",
      "restart_production",
      "delete_resource",
      "scale_production",
      "merge_to_main",
      "modify_production_config"
    ],
    "ReplanConfidenceThreshold": 0.4,
    "CheckpointEveryNSteps": 5
  }
}
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "CosmosDb": {
    "AccountEndpoint": "https://your-account.documents.azure.com:443/",
    "AccountKey": "your-primary-key",
    "DatabaseName": "YourDatabase"
  }
}

ASPNETCORE_ENVIRONMENT=Development
API_PORT=42000
FRONTEND_PORT=42080
API_BASE_URL=http://localhost:42000
SQLSERVER_PORT=42433
SQLSERVER_DB_NAME=AzureOpsCrew
SQLSERVER_SA_PASSWORD=YourStrong@Password
DOCKER_SQLSERVER_PLATFORM=linux/amd64

JWT_ISSUER=AzureOpsCrew
JWT_AUDIENCE=AzureOpsCrewFrontend
JWT_SIGNING_KEY=ChangeThisDevelopmentOnlySigningKeyWithAtLeast32Chars!
JWT_ACCESS_TOKEN_MINUTES=480

SEEDING_ENABLED=false
AZURE_OPENAI_API_ENDPOINT=
AZURE_OPENAI_API_KEY=

EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=30

BREVO_API_BASE_URL=https://api.brevo.com
BREVO_API_KEY=
BREVO_SENDER_EMAIL=azureopscrew@aoc-app.com
BREVO_SENDER_NAME=Azure Ops Crew

LONG_TERM_MEMORY_TYPE=InMemory
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=azureopscrew

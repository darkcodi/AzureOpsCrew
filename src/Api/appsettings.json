{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "DatabaseProvider": "SqlServer",
  "SqlServer": {
    "ConnectionString": "Server=localhost;Database=AzureOpsCrew;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "AzureOpsCrew",
    "Audience": "AzureOpsCrewFrontend",
    "SigningKey": "",
    "AccessTokenMinutes": 480
  },
  "EmailVerification": {
    "IsEnabled": true,
    "CodeLength": 6,
    "CodeTtlMinutes": 10,
    "ResendCooldownSeconds": 30,
    "MaxVerificationAttempts": 5
  },
  "Brevo": {
    "ApiBaseUrl": "https://api.brevo.com",
    "ApiKey": "",
    "SenderEmail": "azureopscrew@aoc-app.com",
    "SenderName": "Azure Ops Crew"
  },
  "Seeding": {
    "IsEnabled": false,
    "AzureFoundrySeed": {
      "ApiEndpoint": "",
      "Key": "",
      "DefaultModel": ""
    },
    "UserSeed": {
      "Email": "",
      "Username": "",
      "Password": ""
    }
  },
  "LongTermMemory": {
    "Type": "None",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "password"
    }
  }
}

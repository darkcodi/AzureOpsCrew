{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enable": false,
    "ConnectionString": "InstrumentationKey=YOUR_KEY_HERE"
  },
  "DatabaseProvider": "SqlServer",
  "SqlServer": {
    "ConnectionString": "Server=localhost;Database=AzureOpsCrew;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "AzureOpsCrew",
    "Audience": "AzureOpsCrewFrontend",
    "SigningKey": "",
    "AccessTokenMinutes": 480
  },
  "EmailVerification": {
    "IsEnabled": true,
    "CodeLength": 6,
    "CodeTtlMinutes": 10,
    "ResendCooldownSeconds": 30,
    "MaxVerificationAttempts": 5
  },
  "Brevo": {
    "ApiBaseUrl": "https://api.brevo.com",
    "ApiKey": "",
    "SenderEmail": "azureopscrew@aoc-app.com",
    "SenderName": "Azure Ops Crew"
  },
  "Seeding": {
    "IsEnabled": false,
    "AzureFoundrySeed": {
      "ApiEndpoint": "",
      "Key": ""
    }
  },
  "ContextReduction": {
    "SoftThresholdPercent": 0.85,
    "RecentToolBudgetTokens": 12000,
    "MinReservedOutputTokens": 4096,
    "FallbackContextWindowSize": 128000,
    "SafetyMargin": 1.15,
    "CharsPerToken": 4.0
  },
  "LongTermMemory": {
    "Type": "InMemory",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "password"
    }
  }
}

@page "/settings"
@page "/settings/{SectionSlug}"

@inject SettingsService SettingsService
@inject NavigationManager Navigation
@inject AppState AppState
@inject AgentService AgentService

<PageTitle>@GetSettingsPageTitle()</PageTitle>
<MainLayout>
    <LeftSidebar>
        <SettingsSidebar ActiveSection="_activeSection" />
    </LeftSidebar>
    <MainArea>
        <div class="settings-main-area">
            <SettingsContent ActiveSection="_activeSection"
                             Settings="_settings"
                             SavedSettings="_savedSettings"
                             ModifiedProviderIds="_modifiedProviderIds"
                             SelectedProviderId="@_selectedProviderId"
                             OnSelectProvider="id => { _selectedProviderId = id; StateHasChanged(); }"
                             OnSettingsChange="HandleSettingsChange"
                             OnSaveCurrentProvider="HandleSaveCurrentProvider"
                             OnTestProvider="HandleTestProvider"
                             OnRemoveProvider="HandleRemoveProvider"
                             OnToggleSelectedModel="HandleToggleSelectedModel"
                             IsSaving="_isSaving"
                             IsTesting="_isTesting"
                             SaveError="@_saveError"
                             McpServers="_mcpServers"
                             ModifiedMcpServerIds="_modifiedMcpServerIds"
                             SelectedMcpServerId="@_selectedMcpServerId"
                             OnSelectMcpServer="HandleSelectMcpServer"
                             OnMcpServersChange="HandleMcpServersChange"
                             OnSaveCurrentMcpServer="HandleSaveCurrentMcpServer"
                             OnResetCurrentMcpServer="HandleResetCurrentMcpServer"
                             OnRemoveCurrentMcpServer="HandleRemoveCurrentMcpServer"
                             OnSyncMcpServer="HandleSyncMcpServer"
                             OnToggleSelectedMcpServerEnabled="HandleToggleSelectedMcpServerEnabled"
                             OnToggleSelectedMcpServerTool="HandleToggleSelectedMcpServerTool"
                             IsSavingMcpServer="_isSavingMcpServer"
                             IsSyncingMcpServer="_isSyncingMcpServer"
                             IsUpdatingMcpServerTool="_isUpdatingMcpServerTool"
                             UpdatingMcpServerToolName="@_updatingMcpServerToolName"
                             McpServerAuthResetKey="@_mcpServerAuthResetKey"
                             McpServerError="@_mcpServerError"
                             McpReturnToListRequested="_mcpReturnToListRequested"
                             OnMcpReturnToListAcknowledged="HandleMcpReturnToListAcknowledged"
                             Agents="@_agents"
                             OnDeleteAgent="HandleDeleteAgent"
                             OnAgentsChanged="HandleAgentsChanged" />

            @if (HasUnsavedChanges)
            {
                <div class="unsaved-bar">
                    <span class="unsaved-text">Unsaved changes</span>
                    <div class="unsaved-actions">
                        @if (!string.IsNullOrEmpty(_saveError))
                        {
                            <span class="unsaved-error">@_saveError</span>
                        }
                        <button type="button" class="unsaved-btn reset-btn" disabled="@_isSaving" @onclick="HandleReset">
                            Reset
                        </button>
                        <button type="button" class="unsaved-btn save-btn" disabled="@_isSaving" @onclick="HandleSaveAll">
                            @(_isSaving ? "Saving...." : "Save")
                        </button>
                    </div>
                </div>
            }
        </div>
    </MainArea>
    <RightSidebar>
        <SettingsInfoPanel ActiveSection="_activeSection"
                           SelectedProvider="@SelectedProvider"
                           SelectedModels="@(SelectedProvider?.SelectedModels ?? [])"
                           OnToggleSelectedModel="HandleToggleSelectedModel"
                           ProviderTestResult="@CurrentTestResult"
                           SelectedMcpServer="@SelectedMcpServer" />
    </RightSidebar>
</MainLayout>

@code {
    [Parameter] public string? SectionSlug { get; set; }

    private SettingsSection _activeSection = SettingsSection.Providers;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(SectionSlug))
        {
            Navigation.NavigateTo(SettingsSectionRoutes.ToPath(SettingsSection.Providers), replace: true);
            return;
        }
        _activeSection = SettingsSectionRoutes.FromSlug(SectionSlug);
    }

    private static string GetSettingsPageTitle(SettingsSection section) => section switch
    {
        SettingsSection.Account => "Settings - Account",
        SettingsSection.Appearance => "Settings - Appearance",
        SettingsSection.Notifications => "Settings - Notifications",
        SettingsSection.Providers => "Settings - Providers",
        SettingsSection.McpServers => "Settings - MCP Servers",
        SettingsSection.Agents => "Settings - Agents",
        SettingsSection.Routing => "Settings - Routing",
        SettingsSection.Advanced => "Settings - Advanced",
        _ => "Settings"
    };

    private string GetSettingsPageTitle() => GetSettingsPageTitle(_activeSection);

    private SettingsState _settings = new() { Providers = [] };
    private SettingsState _savedSettings = new() { Providers = [] };
    private string? _selectedProviderId;
    private Dictionary<string, ProviderTestResult> _providerTestResults = new();
    private string? _saveError;
    private bool _isSaving;
    private bool _isTesting;

    private List<McpServerConfigurationItem> _mcpServers = [];
    private List<McpServerConfigurationItem> _savedMcpServers = [];
    private string? _selectedMcpServerId;
    private HashSet<string> _modifiedMcpServerIds = [];
    private string? _mcpServerError;
    private bool _isSavingMcpServer;
    private bool _isSyncingMcpServer;
    private bool _isUpdatingMcpServerTool;
    private int _mcpServerAuthResetKey;
    private string? _updatingMcpServerToolName;
    private bool _mcpReturnToListRequested;

    private Provider? SelectedProvider =>
        _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);

    private McpServerConfigurationItem? SelectedMcpServer =>
        _mcpServers.FirstOrDefault(server => server.Id == _selectedMcpServerId);

    private ProviderTestResult? CurrentTestResult =>
        _selectedProviderId != null && _providerTestResults.TryGetValue(_selectedProviderId, out var r) ? r : null;

    private HashSet<string> _modifiedProviderIds = [];
    private IReadOnlyList<AgentDto> _agents = [];

    private bool HasUnsavedChanges =>
        System.Text.Json.JsonSerializer.Serialize(_settings) !=
        System.Text.Json.JsonSerializer.Serialize(_savedSettings);

    protected override async Task OnInitializedAsync()
    {
        var persisted = await SettingsService.LoadFromLocalStorageAsync();

        try
        {
            var apiProviders = await SettingsService.GetProvidersAsync();
            if (apiProviders.Count > 0)
            {
                var sorted = apiProviders
                    .OrderBy(p => p.DateCreated != null && DateTime.TryParse(p.DateCreated, out var d) ? d.Ticks : long.MaxValue)
                    .ToList();
                persisted.Providers = sorted;
                _settings = persisted;
            }
            else
            {
                _settings = persisted;
            }
        }
        catch
        {
            _settings = persisted;
        }

        _savedSettings = _settings.DeepClone();
        _selectedProviderId = _settings.Providers.FirstOrDefault()?.Id;
        await SettingsService.SaveToLocalStorageAsync(_settings);
        ComputeModifiedIds();

        try
        {
            var apiMcpServers = await SettingsService.GetMcpServersAsync();
            _mcpServers = apiMcpServers
                .OrderBy(server => GetMcpServerSortKey(server.DateCreated))
                .Select(server => server.Clone())
                .ToList();
        }
        catch
        {
            _mcpServers = [];
        }

        _savedMcpServers = _mcpServers.Select(server => server.Clone()).ToList();
        _selectedMcpServerId = _mcpServers.FirstOrDefault()?.Id;
        ComputeModifiedMcpServerIds();

        await AppState.LoadAgents(AgentService);
        _agents = AppState.Agents.ToList();
    }

    private void ComputeModifiedIds()
    {
        var savedById = _savedSettings.Providers.ToDictionary(p => p.Id);
        _modifiedProviderIds = _settings.Providers
            .Where(p =>
            {
                if (!savedById.TryGetValue(p.Id, out var saved) || string.IsNullOrEmpty(p.BackendId)) return false;
                return p.Name != saved.Name ||
                       p.Status != saved.Status ||
                       p.ApiKey != saved.ApiKey ||
                       p.BaseUrl != saved.BaseUrl ||
                       p.DefaultModel != saved.DefaultModel ||
                       p.IsDefault != saved.IsDefault ||
                       System.Text.Json.JsonSerializer.Serialize(p.SelectedModels ?? []) !=
                       System.Text.Json.JsonSerializer.Serialize(saved.SelectedModels ?? []);
            })
            .Select(p => p.Id)
            .ToHashSet();
    }

    private void ComputeModifiedMcpServerIds()
    {
        var savedById = _savedMcpServers.ToDictionary(server => server.Id);
        _modifiedMcpServerIds = _mcpServers
            .Where(server =>
            {
                if (!savedById.TryGetValue(server.Id, out var saved) || string.IsNullOrEmpty(server.BackendId)) return false;
                return server.Name != saved.Name ||
                       NormalizeOptionalMcpText(server.Description) != NormalizeOptionalMcpText(saved.Description) ||
                       server.Url != saved.Url;
            })
            .Select(server => server.Id)
            .ToHashSet();
    }

    private static string? NormalizeOptionalMcpText(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    /// <summary>Sort key for MCP server by creation date: oldest first. Items without a parseable date go last.</summary>
    private static long GetMcpServerSortKey(string? dateCreated)
    {
        if (string.IsNullOrWhiteSpace(dateCreated)) return long.MaxValue;
        return DateTime.TryParse(dateCreated, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.RoundtripKind, out var dt) ? dt.Ticks : long.MaxValue;
    }

    private void HandleSettingsChange(SettingsState updated)
    {
        _settings = updated;
        ComputeModifiedIds();
        StateHasChanged();
    }

    private void HandleSelectMcpServer(string id)
    {
        _selectedMcpServerId = id;
        StateHasChanged();
    }

    private void HandleMcpReturnToListAcknowledged()
    {
        _mcpReturnToListRequested = false;
        StateHasChanged();
    }

    private void HandleMcpServersChange(List<McpServerConfigurationItem> updated)
    {
        var previousSelection = _selectedMcpServerId;
        _mcpServers = updated;

        if (string.IsNullOrWhiteSpace(previousSelection))
            _selectedMcpServerId = _mcpServers.LastOrDefault()?.Id;
        else if (_mcpServers.All(server => server.Id != previousSelection))
            _selectedMcpServerId = _mcpServers.LastOrDefault()?.Id;

        ComputeModifiedMcpServerIds();
        StateHasChanged();
    }

    private async Task HandleSaveAll()
    {
        _saveError = null;
        _isSaving = true;
        try
        {
            var response = await SettingsService.SaveProvidersAsync(_settings.Providers);
            MergeSaveResults(response);
            _savedSettings = _settings.DeepClone();
            await SettingsService.SaveToLocalStorageAsync(_settings);
            ComputeModifiedIds();
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleSaveCurrentProvider()
    {
        if (_selectedProviderId == null) return;
        var current = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
        if (current == null) return;

        _saveError = null;
        _isSaving = true;
        try
        {
            var response = await SettingsService.SaveProvidersAsync([current]);
            MergeSaveResults(response);

            var savedProvider = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
            if (savedProvider != null)
            {
                var idx = _savedSettings.Providers.FindIndex(p => p.Id == _selectedProviderId);
                if (idx >= 0)
                    _savedSettings.Providers[idx] = savedProvider.Clone();
                else
                    _savedSettings.Providers.Add(savedProvider.Clone());
            }

            await SettingsService.SaveToLocalStorageAsync(_settings);
            ComputeModifiedIds();
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleSaveCurrentMcpServer(McpServerAuthEditorState? auth)
    {
        if (_selectedMcpServerId == null) return;
        var current = _mcpServers.FirstOrDefault(server => server.Id == _selectedMcpServerId);
        if (current == null) return;

        _mcpServerError = null;
        _isSavingMcpServer = true;
        try
        {
            // Set auth on current before saving (so Create/Update can read it)
            current.Auth = new McpServerAuthSummary { Type = auth?.Type ?? "None" };
            current.BearerToken = auth?.BearerToken ?? "";
            current.Headers = auth?.Headers?.Select(h => new McpServerAuthHeaderEditorItem { Name = h.Name, Value = h.Value }).ToList() ?? [];

            // Find saved server for auth comparison
            var savedServer = _savedMcpServers.FirstOrDefault(s => s.Id == current.Id);

            var savedSnapshot = string.IsNullOrWhiteSpace(current.BackendId)
                ? await SettingsService.CreateMcpServerAsync(current)
                : await SettingsService.UpdateMcpServerAsync(current, savedServer);

            ApplyMcpServerSnapshot(current.Id, savedSnapshot);
            _mcpServerAuthResetKey++;
        }
        catch (Exception ex)
        {
            _mcpServerError = ex.Message;
        }
        finally
        {
            _isSavingMcpServer = false;
        }

        if (_mcpServerError == null)
            _mcpReturnToListRequested = true;
    }

    private async Task HandleRemoveCurrentMcpServer()
    {
        if (_selectedMcpServerId == null) return;

        var currentIndex = _mcpServers.FindIndex(server => server.Id == _selectedMcpServerId);
        if (currentIndex < 0) return;

        var current = _mcpServers[currentIndex];
        if (string.IsNullOrWhiteSpace(current.BackendId))
        {
            _mcpServers.RemoveAt(currentIndex);
        }
        else
        {
            _mcpServerError = null;
            _isSavingMcpServer = true;
            try
            {
                await SettingsService.RemoveMcpServerAsync(current.BackendId);
            }
            catch (Exception ex)
            {
                _mcpServerError = ex.Message;
                return;
            }
            finally
            {
                _isSavingMcpServer = false;
            }

            _mcpServers.RemoveAt(currentIndex);
            _savedMcpServers.RemoveAll(server => server.Id == current.Id);
        }

        _selectedMcpServerId = _mcpServers.Count == 0
            ? null
            : _mcpServers[Math.Min(currentIndex, _mcpServers.Count - 1)].Id;

        _mcpServerError = null;
        _mcpReturnToListRequested = true;
        ComputeModifiedMcpServerIds();
        StateHasChanged();
    }
    private void HandleResetCurrentMcpServer()
    {
        if (_selectedMcpServerId == null) return;

        var current = _mcpServers.FirstOrDefault(server => server.Id == _selectedMcpServerId);
        if (current == null || string.IsNullOrWhiteSpace(current.BackendId))
            return;

        var saved = _savedMcpServers.FirstOrDefault(server => server.Id == current.Id);
        if (saved == null)
            return;

        ApplyMcpServerSnapshot(current.Id, saved.Clone());
        _mcpServerAuthResetKey++;
        _mcpServerError = null;
    }

    private async Task HandleSyncMcpServer()
    {
        if (_selectedMcpServerId == null) return;
        var current = _mcpServers.FirstOrDefault(server => server.Id == _selectedMcpServerId);
        if (current == null || string.IsNullOrWhiteSpace(current.BackendId)) return;
        if (_modifiedMcpServerIds.Contains(current.Id))
        {
            _mcpServerError = "Save name or URL changes before syncing tools.";
            return;
        }

        _mcpServerError = null;
        _isSyncingMcpServer = true;
        try
        {
            var syncedSnapshot = await SettingsService.SyncMcpToolsAsync(current.BackendId);
            ApplyMcpServerSnapshot(current.Id, syncedSnapshot);
        }
        catch (Exception ex)
        {
            _mcpServerError = ex.Message;
        }
        finally
        {
            _isSyncingMcpServer = false;
        }
    }

    private async Task HandleToggleSelectedMcpServerEnabled()
    {
        if (_selectedMcpServerId == null) return;
        var current = _mcpServers.FirstOrDefault(server => server.Id == _selectedMcpServerId);
        if (current == null || string.IsNullOrWhiteSpace(current.BackendId)) return;
        if (_modifiedMcpServerIds.Contains(current.Id))
        {
            _mcpServerError = "Save name or URL changes before toggling availability.";
            return;
        }

        _mcpServerError = null;
        _isSavingMcpServer = true;
        try
        {
            var updatedSnapshot = await SettingsService.SetMcpServerEnabledAsync(current.BackendId, !current.IsEnabled);
            ApplyMcpServerSnapshot(current.Id, updatedSnapshot);
        }
        catch (Exception ex)
        {
            _mcpServerError = ex.Message;
        }
        finally
        {
            _isSavingMcpServer = false;
        }
    }

    private async Task HandleToggleSelectedMcpServerTool(string toolName)
    {
        if (_selectedMcpServerId == null) return;
        var current = _mcpServers.FirstOrDefault(server => server.Id == _selectedMcpServerId);
        if (current == null || string.IsNullOrWhiteSpace(current.BackendId)) return;
        if (_modifiedMcpServerIds.Contains(current.Id))
        {
            _mcpServerError = "Save name or URL changes before changing tool availability.";
            return;
        }

        var currentTool = current.Tools.FirstOrDefault(tool => string.Equals(tool.Name, toolName, StringComparison.Ordinal));
        if (currentTool == null)
            return;

        _mcpServerError = null;
        _isUpdatingMcpServerTool = true;
        _updatingMcpServerToolName = toolName;

        try
        {
            var updatedSnapshot = await SettingsService.SetMcpServerToolEnabledAsync(current.BackendId, toolName, !currentTool.IsEnabled);
            ApplyMcpServerSnapshot(current.Id, updatedSnapshot);
        }
        catch (Exception ex)
        {
            _mcpServerError = ex.Message;
        }
        finally
        {
            _isUpdatingMcpServerTool = false;
            _updatingMcpServerToolName = null;
        }
    }


    private void ApplyMcpServerSnapshot(string localId, McpServerConfigurationItem snapshot)
    {
        var current = _mcpServers.FirstOrDefault(server => server.Id == localId);
        if (current == null) return;

        current.BackendId = string.IsNullOrWhiteSpace(snapshot.BackendId) ? snapshot.Id : snapshot.BackendId;
        current.Name = snapshot.Name;
        current.Description = snapshot.Description;
        current.Url = snapshot.Url;
        current.IsEnabled = snapshot.IsEnabled;
        current.ToolsSyncedAt = snapshot.ToolsSyncedAt;
        current.DateCreated = string.IsNullOrWhiteSpace(snapshot.DateCreated) ? current.DateCreated : snapshot.DateCreated;
        current.Auth = snapshot.Auth.Clone();
        current.Tools = snapshot.Tools.Select(tool => tool.Clone()).ToList();

        var savedClone = current.Clone();
        var savedIndex = _savedMcpServers.FindIndex(server => server.Id == localId);
        if (savedIndex >= 0)
            _savedMcpServers[savedIndex] = savedClone;
        else
            _savedMcpServers.Add(savedClone);

        ComputeModifiedMcpServerIds();
        StateHasChanged();
    }

    private async Task HandleTestProvider()
    {
        if (_selectedProviderId == null) return;
        var current = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
        if (current == null) return;

        _isTesting = true;
        _saveError = null;
        try
        {
            var result = await SettingsService.TestProviderAsync(current);
            _providerTestResults[_selectedProviderId] = result;
        }
        catch (Exception ex)
        {
            _providerTestResults[_selectedProviderId] = new ProviderTestResult
            {
                Success = false,
                Message = ex.Message,
            };
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task HandleRemoveProvider(string providerId)
    {
        var provider = _settings.Providers.FirstOrDefault(p => p.Id == providerId);
        if (provider == null) return;

        if (!string.IsNullOrEmpty(provider.BackendId))
        {
            _isSaving = true;
            try
            {
                await SettingsService.RemoveProviderAsync(provider.BackendId);
            }
            catch (Exception ex)
            {
                _saveError = ex.Message;
                _isSaving = false;
                return;
            }
            finally
            {
                _isSaving = false;
            }
        }

        var deletedIndex = _settings.Providers.FindIndex(p => p.Id == providerId);
        _settings.Providers.RemoveAll(p => p.Id == providerId);
        _savedSettings.Providers.RemoveAll(p => p.Id == providerId);

        var remaining = _settings.Providers;
        _selectedProviderId = deletedIndex > 0 && remaining.Count > 0
            ? remaining[Math.Min(deletedIndex - 1, remaining.Count - 1)].Id
            : remaining.FirstOrDefault()?.Id;

        await SettingsService.SaveToLocalStorageAsync(_settings);
        ComputeModifiedIds();
    }

    private void HandleToggleSelectedModel(string modelId)
    {
        if (_selectedProviderId == null) return;
        var provider = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
        if (provider == null) return;

        var current = provider.SelectedModels ?? [];
        provider.SelectedModels = current.Contains(modelId)
            ? current.Where(id => id != modelId).ToList()
            : [..current, modelId];
        ComputeModifiedIds();
        StateHasChanged();
    }

    private void HandleReset()
    {
        _settings = _savedSettings.DeepClone();
        ComputeModifiedIds();
    }

    private void MergeSaveResults(SaveProvidersResponse? response)
    {
        if (response?.Providers == null || response.Providers.Count == 0) return;
        var byId = response.Providers.ToDictionary(r => r.Id, r => r.BackendId);
        foreach (var p in _settings.Providers)
        {
            if (!byId.TryGetValue(p.Id, out var backendId)) continue;
            p.BackendId = backendId;
            if (p.Status == "disabled") continue;
            p.Status = "enabled";
        }
    }

    private async Task HandleDeleteAgent(Guid agentId)
    {
        try
        {
            await AgentService.DeleteAgentAsync(agentId);
            await AppState.LoadAgents(AgentService, forceReload: true);
            _agents = AppState.Agents.ToList();
            StateHasChanged();
        }
        catch
        {
            // TODO: show error toast
        }
    }

    private async Task HandleAgentsChanged()
    {
        await AppState.LoadAgents(AgentService, forceReload: true);
        _agents = AppState.Agents.ToList();
        StateHasChanged();
    }
}

@page "/servers/{serverId}"
@page "/servers/{serverId}/channels/{channelId}"

<PageTitle>@(AppState.SelectedChannel != null ? $"AOC - #{AppState.SelectedChannel.Name}" : "AzureOpsCrew")</PageTitle>

@using System.Text.Json
@using Serilog
@inject AppState AppState
@implements IAsyncDisposable
@inject ChannelService ChannelService
@inject AgentService AgentService
@inject AgentState AgentState
@inject HttpClient Http
@inject ILoggerFactory LoggerFactory
@inject ILogger<ServerPage> Logger
@inject NavigationManager Navigation

<MainLayout>
    <LeftSidebar>
        <Front.Layout.Components.LeftSidebar Title="Channels">
            <ChannelsList />
            <UserPanel />
        </Front.Layout.Components.LeftSidebar>
    </LeftSidebar>
    <MainArea>
        <ChatArea Messages="_messages"
                  ToolCalls="_emptyToolCalls"
                  Reasonings="_emptyReasonings"
                  ApprovalRequests="_approvalRequests"
                  CurrentUserId="AppState.CurrentUser?.Id"
                  ShowInput="AppState.SelectedChannel != null"
                  Placeholder="@(AppState.SelectedChannel != null ? $"Message #{AppState.SelectedChannel.Name}" : "")"
                  EmptyIcon="@(AppState.SelectedChannel != null ? "#" : "👋")"
                  EmptyTitle="@(AppState.SelectedChannel != null ? $"Welcome to #{AppState.SelectedChannel.Name}!" : "Select a channel")"
                  EmptySubtitle="@(AppState.SelectedChannel != null ? $"This is the start of the #{AppState.SelectedChannel.Name} channel." : "Pick a channel from the sidebar to start chatting.")"
                  TypingUsernames="_typingUsernames"
                  IsAgentRunning="_isAgentRunning"
                  OnStopAgent="StopAgent"
                  ShowStopButton="false"
                  OnSendMessage="SendChannelMessage"
                  OnAgentClick="HandleAgentClickFromChat"
                  Agents="AppState.Agents"
                  OnApprovalRespond="RespondToApproval" />
    </MainArea>
    <RightSidebar>
        <Front.Layout.Components.RightSidebar>
            <MembersList OnAgentClick="OpenAgentMindView" />
        </Front.Layout.Components.RightSidebar>
    </RightSidebar>
</MainLayout>

@if (_mindViewAgent != null)
{
    <AgentMindView Agent="_mindViewAgent"
                   ToolCalls="_mindToolCalls"
                   Reasonings="_mindReasonings"
                   IsLoading="_isMindLoading"
                   OnClose="CloseAgentMindView"
                   OnStop="StopAgent" />
}

@code {
    [Parameter]
    public string? ServerId { get; set; }

    [Parameter]
    public string? ChannelId { get; set; }

    private List<ChatMessageDto> _messages = [];
    private List<ApprovalRequestDto> _approvalRequests = [];
    private List<string> _typingUsernames = [];
    private Guid? _loadedChannelId;
    private IDisposable? _appStateSubscription;
    private ChatHubClient? _hubClient;
    private bool _isAgentRunning;

    private static readonly List<ToolCallDto> _emptyToolCalls = [];
    private static readonly List<ReasoningDto> _emptyReasonings = [];

    private AgentDto? _mindViewAgent;
    private List<ToolCallDto> _mindToolCalls = [];
    private List<ReasoningDto> _mindReasonings = [];
    private bool _isMindLoading;

    private void OnStateChanged() => InvokeAsync(async () =>
    {
        try
        {
            await LoadMessagesIfNeeded();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in OnStateChanged");
        }
    });

    public async ValueTask DisposeAsync()
    {
        _appStateSubscription?.Dispose();
        if (_hubClient != null)
        {
            _hubClient.MessageReceived -= OnMessageReceived;
            _hubClient.ToolCallReceived -= OnToolCallReceived;
            _hubClient.ReasoningReceived -= OnReasoningReceived;
            _hubClient.AgentStatusReceived -= OnAgentStatusReceived;
            _hubClient.ApprovalRequestReceived -= OnApprovalRequestReceived;
            await _hubClient.DisposeAsync();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await AgentState.InitializeAsync();
        SerServerIdAndChannelIdFromRoute();
        await AppState.LoadChannels(ChannelService);
        await AppState.LoadAgents(AgentService);
        _appStateSubscription = AppState.SubscribeCurrentUser(OnStateChanged)
            .Combine(AppState.SubscribeSelectedChannel(OnStateChanged))
            .Combine(AppState.SubscribeChannels(OnStateChanged));
    }

    protected override async Task OnParametersSetAsync()
    {
        SerServerIdAndChannelIdFromRoute();
        await LoadMessagesIfNeeded();
    }

    private async Task LoadMessagesIfNeeded()
    {
        var channelId = AppState.SelectedChannel?.Id;
        if (channelId.HasValue && channelId != _loadedChannelId)
        {
            _loadedChannelId = channelId;
            _typingUsernames = [];
            _isAgentRunning = false;
            _messages = await ChannelService.GetChannelMessagesAsync(channelId.Value);
            _approvalRequests = await ChannelService.GetApprovalsAsync(channelId.Value);

            _mindViewAgent = null;
            _mindToolCalls = [];
            _mindReasonings = [];

            var statuses = await ChannelService.GetAgentStatusesAsync(channelId.Value);
            foreach (var entry in statuses)
            {
                var agent = AppState.Agents.FirstOrDefault(a => a.Id == entry.AgentId);
                if (agent != null)
                {
                    agent.Status = entry.Status;
                    agent.ErrorMessage = string.Equals(entry.Status, "Error", StringComparison.OrdinalIgnoreCase) ? entry.ErrorMessage : null;
                }
            }
            if (statuses.Count > 0)
            {
                _isAgentRunning = statuses.Any(s => string.Equals(s.Status, "Running", StringComparison.OrdinalIgnoreCase));
                foreach (var entry in statuses.Where(s => string.Equals(s.Status, "Running", StringComparison.OrdinalIgnoreCase)))
                {
                    var username = AppState.Agents.FirstOrDefault(a => a.Id == entry.AgentId)?.Username;
                    if (!string.IsNullOrEmpty(username) && !_typingUsernames.Contains(username))
                        _typingUsernames.Add(username);
                }
                AppState.Agents.NotifyChanged();
            }
            StateHasChanged();

            await ConnectToChannelHub(channelId.Value);
        }
    }

    private async Task ConnectToChannelHub(Guid channelId)
    {
        if (_hubClient != null)
        {
            _hubClient.MessageReceived -= OnMessageReceived;
            _hubClient.ToolCallReceived -= OnToolCallReceived;
            _hubClient.ReasoningReceived -= OnReasoningReceived;
            _hubClient.AgentStatusReceived -= OnAgentStatusReceived;
            _hubClient.ApprovalRequestReceived -= OnApprovalRequestReceived;
            await _hubClient.DisposeAsync();
        }

        _hubClient = ChatHubClient.ForChannel(LoggerFactory);
        _hubClient.MessageReceived += OnMessageReceived;
        _hubClient.ToolCallReceived += OnToolCallReceived;
        _hubClient.ReasoningReceived += OnReasoningReceived;
        _hubClient.AgentStatusReceived += OnAgentStatusReceived;
        _hubClient.ApprovalRequestReceived += OnApprovalRequestReceived;

        var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/');
        var hubUrl = $"{baseUrl}/channels/{channelId}/events";
        await _hubClient.ConnectAsync(hubUrl, channelId);
    }

    private async void OnMessageReceived(ChatMessageDto message)
    {
        if (_messages.Any(m => m.Id == message.Id))
            return;

        _messages.Add(message);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SendChannelMessage(string text)
    {
        if (AppState.SelectedChannel == null) return;

        var newMessage = await ChannelService.PostMessageAsync(AppState.SelectedChannel.Id, text);
        if (newMessage != null && !_messages.Any(m => m.Id == newMessage.Id))
        {
            newMessage.IsOwnMessage = true;
            _messages.Add(newMessage);
        }
    }

    private async Task StopAgent()
    {
        var channelId = AppState.SelectedChannel?.Id;
        if (channelId.HasValue && _mindViewAgent != null)
        {
            await ChannelService.StopAgentChannelAsync(channelId.Value, _mindViewAgent.Id);
        }
    }

    private async Task OpenAgentMindView(AgentDto agent)
    {
        _mindViewAgent = agent;
        _isMindLoading = true;
        _mindToolCalls = [];
        _mindReasonings = [];
        StateHasChanged();

        var channelId = AppState.SelectedChannel?.Id;
        if (channelId.HasValue)
        {
            var mind = await AgentService.GetAgentMindForChannelAsync(channelId.Value, agent.Id);
            _mindToolCalls = ExtractToolCalls(mind);
            _mindReasonings = ExtractReasonings(mind, agent.Username);
        }

        _isMindLoading = false;
        StateHasChanged();
    }

    private void CloseAgentMindView()
    {
        _mindViewAgent = null;
        _mindToolCalls = [];
        _mindReasonings = [];
    }

    private async Task HandleAgentClickFromChat(Guid? agentId)
    {
        if (agentId is not { } id) return;
        var agent = AppState.Agents.FirstOrDefault(a => a.Id == id);
        if (agent != null)
            await OpenAgentMindView(agent);
    }

    private async void OnToolCallReceived(ToolCallDto toolCall)
    {
        if (_mindViewAgent == null)
            return;

        if (toolCall.AgentId != _mindViewAgent.Id)
            return;

        var existing = _mindToolCalls.FirstOrDefault(t => t.CallId == toolCall.CallId);
        if (existing != null)
        {
            existing.Result = toolCall.Result;
            existing.IsError = toolCall.IsError;
            existing.IsFinished = toolCall.IsFinished;
        }
        else
        {
            _mindToolCalls.Add(toolCall);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async void OnReasoningReceived(ReasoningDto reasoning)
    {
        if (_mindViewAgent == null)
            return;

        if (reasoning.AgentId != _mindViewAgent.Id)
            return;

        _mindReasonings.Add(reasoning);
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAgentStatusReceived(Guid agentId, string status, string? errorMessage)
    {
        var agent = AppState.Agents.FirstOrDefault(a => a.Id == agentId);
        if (agent != null)
        {
            agent.Status = status;
            agent.ErrorMessage = string.Equals(status, "Error", StringComparison.OrdinalIgnoreCase) ? errorMessage : null;
            AppState.Agents.NotifyChanged();

            var isRunning = string.Equals(status, "Running", StringComparison.OrdinalIgnoreCase);
            var isWaitingForApproval = string.Equals(status, "WaitingForApproval", StringComparison.OrdinalIgnoreCase);
            _isAgentRunning = isRunning;

            if (isRunning)
            {
                if (!_typingUsernames.Contains(agent.Username))
                    _typingUsernames.Add(agent.Username);
            }
            else
            {
                _typingUsernames.Remove(agent.Username);
            }

            var channelId = AppState.SelectedChannel?.Id;
            if (channelId.HasValue)
            {
                if (isRunning || isWaitingForApproval)
                {
                    await AgentState.SetAgentStatusAsync(channelId.Value, ConversationType.Channel, agentId, status, errorMessage);
                }
                else
                {
                    await AgentState.ClearStateAsync(channelId.Value, ConversationType.Channel);
                }
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async void OnApprovalRequestReceived(ApprovalRequestDto approval)
    {
        var existing = _approvalRequests.FirstOrDefault(a => a.ApprovalId == approval.ApprovalId);
        if (existing != null)
        {
            existing.AgentName = approval.AgentName;
            existing.ServerName = approval.ServerName;
            existing.Status = approval.Status;
            existing.Reason = approval.Reason;
            existing.UserResponse = approval.UserResponse;
        }
        else
        {
            _approvalRequests.Add(approval);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RespondToApproval((string approvalId, bool approved) response)
    {
        var channel = AppState.SelectedChannel;
        if (channel == null) return;

        var success = await ChannelService.RespondToApprovalAsync(channel.Id, response.approvalId, response.approved);
        if (!success)
            return;

        var approval = _approvalRequests.FirstOrDefault(a => a.ApprovalId == response.approvalId);
        if (approval != null)
        {
            approval.Status = response.approved ? "approved" : "rejected";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void SerServerIdAndChannelIdFromRoute()
    {
        if (!string.IsNullOrEmpty(ServerId) && Guid.TryParse(ServerId, out var parsedServerId))
        {
            var server = AppState.Servers.FirstOrDefault(s => s.Id == parsedServerId);
            if (server != null)
            {
                AppState.SelectedServer = server;
            }
        }

        if (!string.IsNullOrEmpty(ChannelId) && Guid.TryParse(ChannelId, out var parsedChannelId))
        {
            var channel = AppState.Channels.FirstOrDefault(c => c.Id == parsedChannelId);
            if (channel != null)
            {
                AppState.SelectedChannel = channel;
                return;
            }
        }

        if (string.IsNullOrEmpty(ChannelId) && AppState.LastUsedChannelId.HasValue)
        {
            Navigation.NavigateTo($"/servers/{AppState.SelectedServer?.Id}/channels/{AppState.LastUsedChannelId.Value}");
        }
    }

    private static List<ToolCallDto> ExtractToolCalls(AgentMindResponseDto? mind)
    {
        if (mind?.Events is not { Count: > 0 })
            return [];

        return mind.Events
            .Where(e => e.Widget != null)
            .Select(e =>
            {
                var resultEl = e.Widget!.Result is JsonElement re ? re : (JsonElement?)null;
                return new ToolCallDto
                {
                    ToolName = e.Widget!.ToolName,
                    CallId = e.Widget.CallId,
                    Args = e.Widget.Args is JsonElement argsEl ? argsEl : null,
                    Result = resultEl,
                    IsError = e.Widget.IsError,
                    IsFinished = true,
                    Timestamp = e.Timestamp,
                };
            })
            .ToList();
    }

    private static List<ReasoningDto> ExtractReasonings(AgentMindResponseDto? mind, string? agentName = null)
    {
        if (mind?.Events is not { Count: > 0 })
            return [];

        return mind.Events
            .Where(e => !string.IsNullOrEmpty(e.Reasoning))
            .Select(e => new ReasoningDto
            {
                Text = e.Reasoning!,
                AgentName = agentName,
                Timestamp = e.Timestamp,
            })
            .ToList();
    }
}

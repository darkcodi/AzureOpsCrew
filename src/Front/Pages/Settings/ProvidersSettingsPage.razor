@page "/settings/providers"
@inject SettingsService SettingsService

<SettingsPageShell Section="SettingsSection.Providers">
    <MainContent>
        <div class="section-header">
            <h2 class="section-title">Settings</h2>
            <p class="section-description">Connect model backends (cloud/local). Keys are stored locally and never shown again after save.</p>
        </div>

        <div class="search-bar">
            <span class="search-icon">@((MarkupString)SvgSearch)</span>
            <input type="text" @bind="_searchQuery" @bind:event="oninput" placeholder="Search settings..." class="search-input" />
        </div>

        <div class="providers-layout">
            @* Provider list *@
            <div class="provider-list">
                <h3 class="provider-list-title">Providers</h3>
                <div class="provider-list-items">
                    @foreach (var provider in FilteredProviders)
                    {
                        var isSelected = _selectedProviderId == provider.Id;
                        var badge = GetStatusBadge(provider);
                        <button type="button"
                                class="provider-card @(isSelected ? "selected" : "")"
                                @onclick="() => { _selectedProviderId = provider.Id; StateHasChanged(); }">
                            <span class="provider-card-name">@provider.Name</span>
                            <span class="provider-card-status" style="color: @badge.Color">
                                <span class="status-icon">@((MarkupString)badge.Icon)</span>
                                @badge.Label
                            </span>
                        </button>
                    }
                    <button type="button" class="add-provider-btn" @onclick="() => _addProviderDialogOpen = true">
                        <span class="add-provider-icon">@((MarkupString)SvgPlus)</span>
                        <span>Add Provider</span>
                    </button>
                </div>
            </div>

            @* Provider detail form *@
            @if (SelectedProvider is { } sp)
            {
                var badge = GetStatusBadge(sp);
                var providerType = sp.ProviderType ?? sp.Name;
                var description = GetProviderDescription(providerType);

                <div class="provider-detail">
                    <div class="provider-detail-header">
                        <h3 class="provider-detail-name">@sp.Name</h3>
                        <div class="provider-detail-status">
                            <span class="provider-card-status" style="color: @badge.Color">
                                <span class="status-icon">@((MarkupString)badge.Icon)</span>
                                @badge.Label
                            </span>
                            @if (sp.IsDefault)
                            {
                                <span class="default-label">&middot; Default provider for new agents</span>
                            }
                        </div>
                    </div>

                    @if (description != null)
                    {
                        <div class="provider-description-card">
                            <h4 class="description-label">Description</h4>
                            <p class="description-text">
                                @description.Value.Desc
                                <a href="@description.Value.Url" target="_blank" rel="noopener noreferrer" class="description-link">@description.Value.UrlLabel</a>
                            </p>
                        </div>
                    }

                    @* Type *@
                    <div class="form-field">
                        <label class="form-label">Type</label>
                        <select class="form-select" disabled value="@providerType">
                            <option value="Anthropic">Anthropic</option>
                            <option value="AzureFoundry">Azure Foundry</option>
                            <option value="Ollama (Local)">Ollama (Local)</option>
                            <option value="OpenAI">OpenAI</option>
                            <option value="OpenRouter">OpenRouter</option>
                        </select>
                    </div>

                    @* Name *@
                    <div class="form-field">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-input" value="@sp.Name" placeholder="Provider display name"
                               @oninput="e => UpdateProvider(sp.Id, p => p.Name = e.Value?.ToString() ?? string.Empty)" />
                    </div>

                    @* API Key *@
                    <div class="form-field">
                        <label class="form-label">@GetApiKeyLabel(sp)</label>
                        <div class="input-with-action">
                            <input type="@(_showApiKey ? "text" : "password")" class="form-input has-right-element"
                                   value="@sp.ApiKey"
                                   placeholder="@(!string.IsNullOrEmpty(sp.BackendId) && sp.HasApiKey == true ? "Enter new key only if you want to change it" : "Enter API key...")"
                                   @oninput="e => UpdateProvider(sp.Id, p => p.ApiKey = e.Value?.ToString() ?? string.Empty)" />
                            <button type="button" class="input-action-btn" @onclick="() => _showApiKey = !_showApiKey"
                                    title="@(_showApiKey ? "Hide API key" : "Show API key")">
                                @((MarkupString)(_showApiKey ? SvgEyeOff : SvgEye))
                            </button>
                        </div>
                        <p class="form-description">
                            @{ var apiKeyDesc = GetApiKeyDescription(providerType); }
                            @apiKeyDesc.Text
                            @if (apiKeyDesc.Url != null && apiKeyDesc.LinkText != null)
                            {
                                <a href="@apiKeyDesc.Url" target="_blank" rel="noopener noreferrer" class="description-link">@apiKeyDesc.LinkText</a>
                            }
                        </p>
                    </div>

                    @* Base URL *@
                    <div class="form-field">
                        <label class="form-label">Base URL</label>
                        <input type="text" class="form-input" value="@sp.BaseUrl" placeholder="https://api.example.com/v1"
                               @oninput="e => UpdateProvider(sp.Id, p => p.BaseUrl = e.Value?.ToString() ?? string.Empty)" />
                    </div>

                    @* Selected models *@
                    <div class="form-field">
                        <label class="form-label">Selected models</label>
                        <div class="model-chips-container">
                            @if ((sp.SelectedModels ?? []).Count == 0)
                            {
                                <span class="model-chips-placeholder">Click models in the panel or add one manually</span>
                            }
                            @foreach (var modelId in sp.SelectedModels ?? [])
                            {
                                <span class="model-chip">
                                    @modelId
                                    <button type="button" class="model-chip-remove" @onclick="() => HandleToggleSelectedModel(modelId)">
                                        @((MarkupString)SvgX)
                                    </button>
                                </span>
                            }
                            <span class="custom-model-input-wrapper">
                                <input type="text" class="custom-model-input" @bind="_customModelInput" @bind:event="oninput"
                                       placeholder="Type custom model name..."
                                       @onkeydown="HandleCustomModelKeyDown" />
                                <button type="button" class="input-action-btn" @onclick="AddCustomModel" title="Add custom model">
                                    @((MarkupString)SvgPlus)
                                </button>
                            </span>
                        </div>
                    </div>

                    @* Default model *@
                    <div class="form-field">
                        <label class="form-label">Default model (optional)</label>
                        <select class="form-select"
                                value="@(sp.SelectedModels?.Contains(sp.DefaultModel) == true ? sp.DefaultModel : "")"
                                @onchange="e => UpdateProvider(sp.Id, p => p.DefaultModel = e.Value?.ToString() ?? string.Empty)">
                            <option value="">None</option>
                            @foreach (var m in sp.SelectedModels ?? [])
                            {
                                <option value="@m">@m</option>
                            }
                        </select>
                        <p class="form-description">Choose from your selected models above.</p>
                    </div>

                    @* Enabled toggle *@
                    <div class="form-field">
                        <label class="form-label">Enabled</label>
                        <button type="button" role="switch" aria-checked="@(sp.Status != "disabled")"
                                class="toggle-switch @(sp.Status != "disabled" ? "on" : "")"
                                @onclick="() => ToggleProviderEnabled(sp)">
                            <span class="toggle-knob"></span>
                        </button>
                        <p class="form-description">When off, this provider is disabled and won't be used.</p>
                    </div>

                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <p class="save-error">@_saveError</p>
                    }

                    <div class="action-buttons">
                        <button type="button" class="btn btn-primary"
                                disabled="@(_isSaving || _selectedProviderId == null || !(_modifiedProviderIds.Contains(_selectedProviderId!) || string.IsNullOrEmpty(sp.BackendId)))"
                                @onclick="HandleSaveCurrentProvider">
                            @(_isSaving ? "Saving...." : "Save")
                        </button>
                        <button type="button" class="btn btn-secondary" disabled="@(_isSaving || _isTesting)"
                                @onclick="HandleTestProvider">
                            @(_isTesting ? "Testing...." : "Test")
                        </button>
                        <button type="button" class="btn btn-danger" disabled="@_isSaving"
                                @onclick="HandleRemoveClick">
                            Remove
                        </button>
                    </div>
                </div>
            }
        </div>

        @* ---- Add Provider Dialog ---- *@
        @if (_addProviderDialogOpen)
        {
            <div class="dialog-overlay" @onclick="CloseAddProviderDialog">
                <div class="dialog-box" @onclick:stopPropagation="true">
                    <div class="dialog-header">
                        <h3 class="dialog-title">Add provider</h3>
                        <p class="dialog-description">Choose a provider to add to your settings.</p>
                    </div>
                    <div class="dialog-body">
                        @foreach (var kp in KnownProviders)
                        {
                            <button type="button" class="provider-option" @onclick="() => AddProvider(kp)">
                                <span class="provider-option-icon">@((MarkupString)kp.SvgIcon)</span>
                                <span>@kp.Name</span>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @* ---- Remove Provider Dialog ---- *@
        @if (_removeProviderPending != null)
        {
            <div class="dialog-overlay" @onclick="() => _removeProviderPending = null">
                <div class="dialog-box" @onclick:stopPropagation="true">
                    <div class="dialog-header">
                        <h3 class="dialog-title">Remove Provider</h3>
                        <div class="dialog-description">
                            <p>Are you sure you want to remove <strong class="text-white">@_removeProviderPending.Name</strong>?</p>
                            <p>This cannot be undone.</p>
                        </div>
                    </div>
                    <div class="dialog-footer">
                        <button type="button" class="btn btn-secondary" disabled="@_isRemovingProvider"
                                @onclick="() => _removeProviderPending = null">
                            Cancel
                        </button>
                        <button type="button" class="btn btn-danger" disabled="@_isRemovingProvider"
                                @onclick="ConfirmRemoveProvider">
                            @(_isRemovingProvider ? "Removing...." : "Remove")
                        </button>
                    </div>
                </div>
            </div>
        }
    </MainContent>
    <InfoPanelContent>
        @if (SelectedProvider != null)
        {
            @RenderProviderInfo()
        }
        else
        {
            @RenderGeneralProviderInfo()
        }
    </InfoPanelContent>
    <FooterContent>
        @if (HasUnsavedChanges)
        {
            <div class="unsaved-bar">
                <span class="unsaved-text">Unsaved changes</span>
                <div class="unsaved-actions">
                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <span class="unsaved-error">@_saveError</span>
                    }
                    <button type="button" class="unsaved-btn reset-btn" disabled="@_isSaving" @onclick="HandleReset">
                        Reset
                    </button>
                    <button type="button" class="unsaved-btn save-btn" disabled="@_isSaving" @onclick="HandleSaveAll">
                        @(_isSaving ? "Saving...." : "Save")
                    </button>
                </div>
            </div>
        }
    </FooterContent>
</SettingsPageShell>

@code {
    // ---- Provider state (from SettingsPage) ----
    private SettingsState _settings = new() { Providers = [] };
    private SettingsState _savedSettings = new() { Providers = [] };
    private string? _selectedProviderId;
    private Dictionary<string, ProviderTestResult> _providerTestResults = new();
    private string? _saveError;
    private bool _isSaving;
    private bool _isTesting;
    private HashSet<string> _modifiedProviderIds = [];

    // ---- Local UI state (from ProvidersSettingsSection) ----
    private string _searchQuery = "";
    private bool _showApiKey;
    private bool _addProviderDialogOpen;
    private Provider? _removeProviderPending;
    private bool _isRemovingProvider;
    private string _customModelInput = "";

    // ---- Info panel state (from SettingsInfoPanel) ----
    private bool _modelsExpanded;
    private string _modelsSearchQuery = "";

    // ---- Computed ----
    private Provider? SelectedProvider =>
        _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);

    private ProviderTestResult? CurrentTestResult =>
        _selectedProviderId != null && _providerTestResults.TryGetValue(_selectedProviderId, out var r) ? r : null;

    private bool HasUnsavedChanges =>
        System.Text.Json.JsonSerializer.Serialize(_settings) !=
        System.Text.Json.JsonSerializer.Serialize(_savedSettings);

    private List<Provider> FilteredProviders =>
        _settings.Providers
            .Where(p => p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.DateCreated != null && DateTime.TryParse(p.DateCreated, out var d) ? d.Ticks : long.MaxValue)
            .ToList();

    // ---- Lifecycle ----
    protected override async Task OnInitializedAsync()
    {
        var persisted = await SettingsService.LoadFromLocalStorageAsync();

        try
        {
            var apiProviders = await SettingsService.GetProvidersAsync();
            if (apiProviders.Count > 0)
            {
                var sorted = apiProviders
                    .OrderBy(p => p.DateCreated != null && DateTime.TryParse(p.DateCreated, out var d) ? d.Ticks : long.MaxValue)
                    .ToList();
                persisted.Providers = sorted;
                _settings = persisted;
            }
            else
            {
                _settings = persisted;
            }
        }
        catch
        {
            _settings = persisted;
        }

        _savedSettings = _settings.DeepClone();
        _selectedProviderId = _settings.Providers.FirstOrDefault()?.Id;
        await SettingsService.SaveToLocalStorageAsync(_settings);
        ComputeModifiedIds();
    }

    // ---- Provider handlers (from SettingsPage) ----
    private void HandleSettingsChange()
    {
        ComputeModifiedIds();
        StateHasChanged();
    }

    private async Task HandleSaveAll()
    {
        _saveError = null;
        _isSaving = true;
        try
        {
            var response = await SettingsService.SaveProvidersAsync(_settings.Providers);
            MergeSaveResults(response);
            _savedSettings = _settings.DeepClone();
            await SettingsService.SaveToLocalStorageAsync(_settings);
            ComputeModifiedIds();
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleSaveCurrentProvider()
    {
        if (_selectedProviderId == null) return;
        var current = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
        if (current == null) return;

        _saveError = null;
        _isSaving = true;
        try
        {
            var response = await SettingsService.SaveProvidersAsync([current]);
            MergeSaveResults(response);

            var savedProvider = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
            if (savedProvider != null)
            {
                var idx = _savedSettings.Providers.FindIndex(p => p.Id == _selectedProviderId);
                if (idx >= 0)
                    _savedSettings.Providers[idx] = savedProvider.Clone();
                else
                    _savedSettings.Providers.Add(savedProvider.Clone());
            }

            await SettingsService.SaveToLocalStorageAsync(_settings);
            ComputeModifiedIds();
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleTestProvider()
    {
        if (_selectedProviderId == null) return;
        var current = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
        if (current == null) return;

        _isTesting = true;
        _saveError = null;
        try
        {
            var result = await SettingsService.TestProviderAsync(current);
            _providerTestResults[_selectedProviderId] = result;
        }
        catch (Exception ex)
        {
            _providerTestResults[_selectedProviderId] = new ProviderTestResult
            {
                Success = false,
                Message = ex.Message,
            };
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task HandleRemoveProvider(string providerId)
    {
        var provider = _settings.Providers.FirstOrDefault(p => p.Id == providerId);
        if (provider == null) return;

        if (!string.IsNullOrEmpty(provider.BackendId))
        {
            _isSaving = true;
            try
            {
                await SettingsService.RemoveProviderAsync(provider.BackendId);
            }
            catch (Exception ex)
            {
                _saveError = ex.Message;
                _isSaving = false;
                return;
            }
            finally
            {
                _isSaving = false;
            }
        }

        var deletedIndex = _settings.Providers.FindIndex(p => p.Id == providerId);
        _settings.Providers.RemoveAll(p => p.Id == providerId);
        _savedSettings.Providers.RemoveAll(p => p.Id == providerId);

        var remaining = _settings.Providers;
        _selectedProviderId = deletedIndex > 0 && remaining.Count > 0
            ? remaining[Math.Min(deletedIndex - 1, remaining.Count - 1)].Id
            : remaining.FirstOrDefault()?.Id;

        await SettingsService.SaveToLocalStorageAsync(_settings);
        ComputeModifiedIds();
    }

    private void HandleToggleSelectedModel(string modelId)
    {
        if (_selectedProviderId == null) return;
        var provider = _settings.Providers.FirstOrDefault(p => p.Id == _selectedProviderId);
        if (provider == null) return;

        var current = provider.SelectedModels ?? [];
        provider.SelectedModels = current.Contains(modelId)
            ? current.Where(id => id != modelId).ToList()
            : [..current, modelId];
        ComputeModifiedIds();
        StateHasChanged();
    }

    private void HandleReset()
    {
        _settings = _savedSettings.DeepClone();
        ComputeModifiedIds();
    }

    private void MergeSaveResults(SaveProvidersResponse? response)
    {
        if (response?.Providers == null || response.Providers.Count == 0) return;
        var byId = response.Providers.ToDictionary(r => r.Id, r => r.BackendId);
        foreach (var p in _settings.Providers)
        {
            if (!byId.TryGetValue(p.Id, out var backendId)) continue;
            p.BackendId = backendId;
            if (p.Status == "disabled") continue;
            p.Status = "enabled";
        }
    }

    private void ComputeModifiedIds()
    {
        var savedById = _savedSettings.Providers.ToDictionary(p => p.Id);
        _modifiedProviderIds = _settings.Providers
            .Where(p =>
            {
                if (!savedById.TryGetValue(p.Id, out var saved) || string.IsNullOrEmpty(p.BackendId)) return false;
                return p.Name != saved.Name ||
                       p.Status != saved.Status ||
                       p.ApiKey != saved.ApiKey ||
                       p.BaseUrl != saved.BaseUrl ||
                       p.DefaultModel != saved.DefaultModel ||
                       p.IsDefault != saved.IsDefault ||
                       System.Text.Json.JsonSerializer.Serialize(p.SelectedModels ?? []) !=
                       System.Text.Json.JsonSerializer.Serialize(saved.SelectedModels ?? []);
            })
            .Select(p => p.Id)
            .ToHashSet();
    }

    // ---- Section UI helpers (from ProvidersSettingsSection) ----
    private void UpdateProvider(string id, Action<Provider> updater)
    {
        var provider = _settings.Providers.FirstOrDefault(p => p.Id == id);
        if (provider == null) return;
        updater(provider);
        HandleSettingsChange();
    }

    private void CloseAddProviderDialog() => _addProviderDialogOpen = false;

    private void AddProvider(KnownProvider kp)
    {
        var existingIds = _settings.Providers.Select(p => p.Id).ToHashSet();
        var newId = existingIds.Contains(kp.Id) ? $"{kp.Id}-{DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}" : kp.Id;
        _settings.Providers.Add(new Provider
        {
            Id = newId,
            Name = kp.Name,
            ProviderType = kp.ProviderType,
            Status = "draft",
            ApiKey = "",
            BaseUrl = kp.BaseUrl,
            DefaultModel = "",
            Timeout = kp.Timeout,
            RateLimit = kp.RateLimit,
        });
        _selectedProviderId = newId;
        HandleSettingsChange();
        _addProviderDialogOpen = false;
    }

    private async Task ConfirmRemoveProvider()
    {
        if (_removeProviderPending == null) return;
        _isRemovingProvider = true;
        try
        {
            await HandleRemoveProvider(_removeProviderPending.Id);
            _removeProviderPending = null;
        }
        finally
        {
            _isRemovingProvider = false;
        }
    }

    private async Task HandleRemoveClick()
    {
        if (SelectedProvider == null) return;
        if (string.IsNullOrEmpty(SelectedProvider.BackendId))
        {
            await HandleRemoveProvider(SelectedProvider.Id);
        }
        else
        {
            _removeProviderPending = SelectedProvider;
        }
    }

    private void AddCustomModel()
    {
        var name = _customModelInput.Trim();
        if (string.IsNullOrEmpty(name) || SelectedProvider == null) return;
        var current = SelectedProvider.SelectedModels ?? [];
        if (current.Contains(name)) return;
        SelectedProvider.SelectedModels = [..current, name];
        HandleSettingsChange();
        _customModelInput = "";
    }

    private void ToggleProviderEnabled(Provider p)
    {
        var isEnabled = p.Status != "disabled";
        if (isEnabled)
        {
            p.Status = "disabled";
        }
        else
        {
            p.Status = string.IsNullOrEmpty(p.BackendId) ? "draft" : "enabled";
        }
        HandleSettingsChange();
    }

    private void HandleCustomModelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddCustomModel();
    }

    // ---- Info panel render helpers ----
    private static string FormatCheckedAt(string? checkedAt)
    {
        if (string.IsNullOrEmpty(checkedAt)) return "\u2014";
        if (!DateTime.TryParse(checkedAt, out var d)) return checkedAt;
        var diff = DateTime.UtcNow - d.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours} h ago";
        return d.ToLocalTime().ToString("g");
    }

    private RenderFragment RenderProviderInfo() => __builder =>
    {
        var hasResult = CurrentTestResult != null;
        var statusColor = hasResult && CurrentTestResult!.Success
            ? "hsl(145, 65%, 45%)"
            : hasResult
                ? "hsl(0, 70%, 55%)"
                : "hsl(214, 5%, 55%)";

        @* ── Test Result ── *@
        <div class="info-section">
            <h4 class="info-section-title">Test result</h4>
            <div class="test-result-card">
                @if (!hasResult)
                {
                    <p class="info-muted">Press "Test" to check connectivity and see latency, last check, and quota.</p>
                }
                else
                {
                    <div class="test-result-header">
                        <span class="status-dot" style="background-color: @statusColor;"></span>
                        <span class="test-provider-name">@SelectedProvider!.Name</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row-label">Latency</span>
                        <span class="info-row-value">@(CurrentTestResult!.LatencyMs != null ? $"{CurrentTestResult.LatencyMs} ms" : "\u2014")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row-label">Last check</span>
                        <span class="info-row-value">@FormatCheckedAt(CurrentTestResult!.CheckedAt)</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row-label">Quota</span>
                        <span class="info-row-value" style="color: @(CurrentTestResult!.Success ? "hsl(145, 65%, 45%)" : "hsl(0, 70%, 55%)")">
                            @(CurrentTestResult!.Quota ?? "\u2014")
                        </span>
                    </div>
                }
            </div>
        </div>

        @* ── Available Models ── *@
        <div class="info-section">
            <h4 class="info-section-title">Available models</h4>
            <div class="models-list">
                @if (CurrentTestResult?.AvailableModels == null || CurrentTestResult.AvailableModels.Count == 0)
                {
                    <p class="info-muted">Press "Test" to see available models.</p>
                }
                else
                {
                    var selectedModels = SelectedProvider?.SelectedModels ?? [];
                    var all = CurrentTestResult.AvailableModels.OrderBy(m => m.Id, StringComparer.OrdinalIgnoreCase).ToList();
                    var selectedSet = selectedModels.ToHashSet();
                    var selectedSorted = all.Where(m => selectedSet.Contains(m.Id)).ToList();
                    var unselected = all.Where(m => !selectedSet.Contains(m.Id)).ToList();
                    var models = selectedSorted.Concat(unselected).ToList();

                    var query = _modelsSearchQuery.Trim().ToLowerInvariant();
                    var filtered = string.IsNullOrEmpty(query)
                        ? models
                        : models.Where(m => m.Id.Contains(query, StringComparison.OrdinalIgnoreCase) || m.Name.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();
                    const int initialCount = 5;
                    var showAll = _modelsExpanded || filtered.Count <= initialCount;
                    var visible = showAll ? filtered : filtered.Take(initialCount).ToList();
                    var hiddenCount = filtered.Count - initialCount;

                    <div class="models-search">
                        <span class="models-search-icon">@((MarkupString)SvgInfoSearch)</span>
                        <input type="search" class="models-search-input" placeholder="Search models..."
                               @bind="_modelsSearchQuery" @bind:event="oninput" />
                    </div>

                    @if (filtered.Count == 0)
                    {
                        <p class="info-muted">
                            @(string.IsNullOrEmpty(query) ? "No models available." : $"No models match \"{_modelsSearchQuery.Trim()}\".")
                        </p>
                    }
                    else
                    {
                        @foreach (var m in visible)
                        {
                            var isDefault = !string.IsNullOrEmpty(SelectedProvider?.DefaultModel) &&
                                            (m.Id == SelectedProvider.DefaultModel || m.Name == SelectedProvider.DefaultModel);
                            var isSelected = selectedSet.Contains(m.Id);
                            var showDefaultStyle = isDefault && isSelected;
                            var borderStyle = showDefaultStyle
                                ? "2px solid hsl(142, 58%, 45%)"
                                : isSelected
                                    ? "1px solid hsl(235, 86%, 65%)"
                                    : "1px solid transparent";

                            <div class="model-item @(showDefaultStyle ? "default-model" : "")"
                                 style="border: @borderStyle; @(showDefaultStyle ? "font-weight:600;" : "")"
                                 title="@m.Name"
                                 @onclick="() => HandleToggleSelectedModel(m.Id)">
                                @m.Id
                            </div>
                        }

                        @if (!showAll && hiddenCount > 0)
                        {
                            <button type="button" class="show-more-btn" @onclick="() => _modelsExpanded = true">
                                <span>@((MarkupString)SvgChevronDown)</span>
                                Show @hiddenCount more
                            </button>
                        }
                        @if (showAll && filtered.Count > initialCount)
                        {
                            <button type="button" class="show-more-btn" @onclick="() => _modelsExpanded = false">
                                <span>@((MarkupString)SvgChevronUp)</span>
                                Show less
                            </button>
                        }
                    }
                }
            </div>
        </div>

        @* ── Notes ── *@
        <div class="info-section">
            <h4 class="info-section-title">Notes</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Keys are encrypted at rest.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Use profiles (dev/prod) to switch endpoints.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Agents can override the default provider/model.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderGeneralProviderInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Providers</h4>
            <p class="info-muted-body">Select a provider from the list to view its test result, available models, and configuration details.</p>
        </div>
        <div class="info-section">
            <h4 class="info-section-title">Quick tips</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Click a provider to see its details.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Use "Test" to verify connectivity.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>The default provider is used for new agents.</span></li>
            </ul>
        </div>
    };

    // ---- Status badge helper ----
    private (string Icon, string Color, string Label) GetStatusBadge(Provider p)
    {
        if (_modifiedProviderIds.Contains(p.Id))
            return (SvgPencil, "hsl(40, 85%, 55%)", "Modified");
        if (string.IsNullOrEmpty(p.BackendId))
            return (SvgFileEdit, "hsl(214, 60%, 55%)", "Draft");
        return p.Status switch
        {
            "enabled" => (SvgCircle, "hsl(145, 65%, 45%)", "Enabled"),
            "disabled" => (SvgXCircle, "hsl(214, 5%, 55%)", "Disabled"),
            _ => (SvgFileEdit, "hsl(214, 60%, 55%)", "Draft"),
        };
    }

    // ---- Provider description helpers ----
    private static (string Desc, string Url, string UrlLabel)? GetProviderDescription(string? providerType) =>
        providerType switch
        {
            "OpenRouter" => ("OpenRouter is a unified API for LLMs. Use one API key to access many models with better prices and uptime.", "https://openrouter.ai/", "openrouter.ai"),
            "OpenAI" => ("OpenAI provides GPT models and the ChatGPT API. Create an account and use the API for completions, embeddings, and more.", "https://platform.openai.com/", "platform.openai.com"),
            "Anthropic" => ("Anthropic builds Claude, a family of AI assistants. Use the API for chat, long context, and tool use.", "https://www.anthropic.com/", "anthropic.com"),
            "Ollama (Local)" => ("Ollama runs LLMs locally on your machine. No API key or cloud account needed\u2014install and pull models to get started.", "https://ollama.com/", "ollama.com"),
            "AzureFoundry" => ("Azure AI Foundry (formerly Azure AI Studio) provides access to OpenAI models and other AI services hosted on Azure.", "https://ai.azure.com/", "ai.azure.com"),
            _ => null,
        };

    private static (string Text, string? Url, string? LinkText) GetApiKeyDescription(string? providerType) =>
        providerType switch
        {
            "OpenRouter" => ("Get your API key at ", "https://openrouter.ai/settings/keys", "openrouter.ai/settings/keys"),
            "OpenAI" => ("Get your API key at ", "https://platform.openai.com/api-keys", "platform.openai.com/api-keys"),
            "Anthropic" => ("Get your API key at ", "https://console.anthropic.com", "console.anthropic.com"),
            "Ollama (Local)" => ("No API key needed for local use.", null, null),
            "AzureFoundry" => ("Get your API key from your Azure OpenAI resource in the Azure Portal.", null, null),
            _ => ("", null, null),
        };

    private static string GetApiKeyLabel(Provider p)
    {
        var pt = p.ProviderType ?? p.Name;
        if (pt == "Ollama (Local)") return "API Key (optional)";
        if (!string.IsNullOrEmpty(p.BackendId) && p.HasApiKey == true) return "New API Key (leave blank to keep existing)";
        return "API Key";
    }


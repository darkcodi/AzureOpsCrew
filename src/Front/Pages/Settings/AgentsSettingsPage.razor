@page "/settings/agents"
@inject AgentService AgentService
@inject SettingsService SettingsService
@inject AppState AppState
@inject MarkdownService MarkdownSvc

<SettingsPageShell Section="SettingsSection.Agents">
    <MainContent>
        <div class="agents-section">
            <div class="section-header">
                <h2 class="section-title">Agents</h2>
                <p class="section-description">Configure default agent behaviors, model assignments, system prompts, and MCP tools.</p>
            </div>
            @if (_agentsSubView == "list")
            {
                <div class="agents-list">
                    @foreach (var agent in _agents)
                    {
                        <div class="agent-row">
                            <div class="agent-row-avatar" style="background-color: @agent.Color;">
                                @GetAgentAvatar(agent)
                            </div>
                            <div class="agent-row-info">
                                <span class="agent-row-name">@agent.Username</span>
                                <span class="agent-row-model">@agent.Model</span>
                            </div>
                            <div class="agent-row-actions">
                                <button type="button" class="agent-row-btn agent-row-btn-edit" title="Edit @agent.Username" @onclick="() => OpenEditAgent(agent)">
                                    @((MarkupString)SvgPencil)
                                </button>
                                <button type="button" class="agent-row-btn agent-row-btn-delete" title="Delete @agent.Username" @onclick="() => _deleteAgentPending = agent">
                                    @((MarkupString)SvgTrash2)
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <div class="agents-create-footer">
                    <button type="button" class="agents-create-btn" @onclick="OpenCreateAgent">
                        <span class="agents-create-icon">@((MarkupString)SvgPlus)</span>
                        <span>Create New Agent</span>
                    </button>
                </div>
            }
            else
            {
                var statusBadge = GetAgentStatusBadge();

                <div class="agents-back-bar">
                    <button type="button" class="agents-back-btn" @onclick="BackToAgentList" aria-label="Back to list">
                        <span class="agents-back-icon">@((MarkupString)SvgChevronLeft)</span>
                        <span>Back to list</span>
                    </button>
                </div>
                <div class="agent-form">
                    <div class="agent-form-status">
                        <span class="provider-card-status" style="color: @statusBadge.Color">
                            <span class="status-icon">@((MarkupString)statusBadge.Icon)</span>
                            @statusBadge.Label
                        </span>
                    </div>
                    <div class="agent-form-field">
                        <label for="agent-name" class="agent-form-label">Agent Name</label>
                        <input id="agent-name" type="text" class="agent-form-input" placeholder="e.g. researchassistant"
                               @bind="_agentName" @bind:event="oninput" />
                        <span class="agent-form-helper">Lowercase letters and numbers only, 2-30 characters</span>
                    </div>
                    <div class="agent-form-field">
                        <span class="agent-form-label">Color</span>
                        <div class="agent-color-swatches">
                            @foreach (var c in AgentColors)
                            {
                                var isSelected = _agentColor == c;
                                <button type="button" class="agent-color-swatch @(isSelected ? "selected" : "")"
                                        style="background-color: @c;" @onclick="() => _agentColor = c"
                                        aria-label="Select color @c"></button>
                            }
                        </div>
                    </div>
                    <div class="agent-form-field">
                        <label for="agent-provider" class="agent-form-label">Provider</label>
                        @if (EnabledProviders.Count == 0)
                        {
                            <div class="agent-form-message agent-form-message-error">No enabled providers found. Please enable a provider in Settings.</div>
                        }
                        else
                        {
                            <select id="agent-provider" class="agent-form-select" value="@_agentProviderId" @onchange="OnAgentProviderChanged">
                                @foreach (var p in EnabledProviders)
                                {
                                    <option value="@p.BackendId">@p.Name (@(p.ProviderType ?? p.Name))</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="agent-form-field">
                        <label for="agent-model" class="agent-form-label">LLM Model</label>
                        @if (AgentFormProviderModels.Count == 0)
                        {
                            <div class="agent-form-message">@(string.IsNullOrEmpty(_agentProviderId) ? "Select a provider first." : "No selected models for this provider.")</div>
                        }
                        else
                        {
                            <select id="agent-model" class="agent-form-select" @bind="_agentModel">
                                @foreach (var m in AgentFormProviderModels)
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="agent-form-field">
                        <label for="agent-prompt" class="agent-form-label">System Prompt</label>
                        <textarea id="agent-prompt" class="agent-form-textarea" rows="4" placeholder="Describe the agent's role and behavior..."
                                  @bind="_agentPrompt" @bind:event="oninput"></textarea>
                    </div>
                    <div class="agent-form-field agent-mcp-field">
                        <div class="agent-mcp-header">
                            <div>
                                <label class="agent-form-label">MCP Servers</label>
                                <p class="agent-mcp-subtitle">Attach globally enabled MCP servers to this agent and choose which synced tools it can use.</p>
                            </div>
                        </div>

                        @if (AgentAssignableMcpServers.Count == 0)
                        {
                            <div class="agent-form-message">No saved and enabled MCP servers are available yet. Configure them in the MCP Servers section first.</div>
                        }
                        else
                        {
                            <div class="mcp-server-list">
                                @foreach (var server in AgentAssignableMcpServers)
                                {
                                    var isServerEnabledForAgent = IsAgentMcpServerEnabled(server);
                                    var enabledToolNames = GetAgentEnabledToolNames(server);
                                    var tools = GetAgentVisibleTools(server);
                                    var canToggleServer = !_isSavingAgent && (server.IsEnabled || isServerEnabledForAgent);
                                    var canToggleTool = !_isSavingAgent && isServerEnabledForAgent;
                                    var enabledToolsCount = tools.Count(t => enabledToolNames.Contains(t.Name));
                                    var isExpanded = _expandedAgentMcpServerIds.Contains(server.Id);
                                    var hasTools = tools.Count > 0;

                                    <div class="mcp-server-card">
                                        <div class="mcp-avatar-wrapper">
                                            <span class="mcp-avatar" style="background: @GetMcpAvatarBackground(server.Name)">
                                                @GetMcpAvatarLetter(server.Name)
                                            </span>
                                            @if (isServerEnabledForAgent)
                                            {
                                                <span class="mcp-status-dot"></span>
                                            }
                                        </div>

                                        <div class="mcp-card-body">
                                            <div class="mcp-name-row">
                                                <span class="mcp-server-name">@server.Name</span>
                                                @if (!server.IsEnabled)
                                                {
                                                    <span class="mcp-server-status-text">Disabled</span>
                                                }
                                            </div>

                                            @if (isServerEnabledForAgent && hasTools)
                                            {
                                                @if (!isExpanded)
                                                {
                                                    <button type="button" class="mcp-tools-toggle" @onclick="() => ToggleAgentMcpToolsExpanded(server.Id)">
                                                        @enabledToolsCount of @tools.Count tools enabled
                                                        <span class="mcp-chevron">@((MarkupString)SvgChevron)</span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <div class="mcp-tools-expanded">
                                                        @foreach (var tool in tools)
                                                        {
                                                            var isToolEnabled = enabledToolNames.Contains(tool.Name);
                                                            <div class="mcp-tool-chip-wrapper">
                                                                <span class="mcp-tool-chip @(isToolEnabled ? "" : "disabled") @(canToggleTool ? "clickable" : "")"
                                                                      @onmouseenter="() => ShowMcpToolTooltip(server.Id, tool.Name)"
                                                                      @onmouseleave="HideMcpToolTooltip"
                                                                      @onclick="() => ToggleAgentMcpTool(server, tool)">@tool.Name</span>
                                                                @if (_hoveredMcpToolKey == $"{server.Id}|{tool.Name}" && !string.IsNullOrWhiteSpace(tool.Description))
                                                                {
                                                                    <div class="mcp-tool-tooltip">
                                                                        <div class="markdown-content">
                                                                            @((MarkupString)MarkdownSvc.ConvertToHtml(tool.Description))
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                    <button type="button" class="mcp-tools-toggle" @onclick="() => ToggleAgentMcpToolsExpanded(server.Id)">
                                                        Show less
                                                        <span class="mcp-chevron up">@((MarkupString)SvgChevron)</span>
                                                    </button>
                                                }
                                            }
                                            else if (isServerEnabledForAgent && !hasTools)
                                            {
                                                <span class="mcp-tools-empty">No enabled tools available</span>
                                            }
                                        </div>

                                        <button type="button" role="switch" aria-checked="@isServerEnabledForAgent"
                                                class="toggle-switch @(isServerEnabledForAgent ? "on" : "")"
                                                disabled="@(!canToggleServer)"
                                                @onclick="() => ToggleAgentMcpServer(server)">
                                            <span class="toggle-knob"></span>
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-primary agent-form-save"
                            disabled="@(!CanSaveAgent)"
                            @onclick="SaveAgent">
                        <span class="agent-form-save-icon">@((MarkupString)SvgSave)</span>
                        <span>@(_isSavingAgent ? "Saving..." : IsDraftAgent ? "Create Agent" : "Save Changes")</span>
                    </button>
                    @if (!string.IsNullOrEmpty(_agentSaveError))
                    {
                        <div class="agent-form-error">@_agentSaveError</div>
                    }
                </div>
            }
        </div>

        @* ---- Delete Agent Dialog ---- *@
        @if (_deleteAgentPending != null)
        {
            <div class="dialog-overlay" @onclick="() => _deleteAgentPending = null">
                <div class="dialog-box" @onclick:stopPropagation="true" role="dialog" aria-labelledby="delete-agent-title" aria-describedby="delete-agent-desc">
                    <div class="dialog-header">
                        <h3 id="delete-agent-title" class="dialog-title">Delete Agent</h3>
                        <div id="delete-agent-desc" class="dialog-description">
                            <p>Are you sure you want to delete <strong class="text-white">@_deleteAgentPending.Username</strong>?</p>
                            <p>This cannot be undone.</p>
                        </div>
                    </div>
                    <div class="dialog-footer">
                        <button type="button" class="btn btn-secondary" disabled="@_isDeletingAgent"
                                @onclick="() => _deleteAgentPending = null">
                            Cancel
                        </button>
                        <button type="button" class="btn btn-danger" disabled="@_isDeletingAgent"
                                @onclick="ConfirmDeleteAgent">
                            @(_isDeletingAgent ? "Deleting...." : "Delete Agent")
                        </button>
                    </div>
                </div>
            </div>
        }
    </MainContent>
    <InfoPanelContent>
        <div class="info-section">
            <h4 class="info-section-title">Agents</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Each agent can have its own provider and model.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>System prompts define the agent's personality and capabilities.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>MCP connections enable external tool integration.</span></li>
            </ul>
        </div>
    </InfoPanelContent>
</SettingsPageShell>

@code {
    // ---- Page data ----
    private IReadOnlyList<AgentDto> _agents = [];
    private SettingsState _settings = new() { Providers = [] };
    private List<McpServerConfigurationItem> _mcpServers = [];

    // ---- Agent form state ----
    private AgentDto? _deleteAgentPending;
    private bool _isDeletingAgent;
    private string _agentsSubView = "list";
    private AgentDto? _editingAgent;
    private string _agentName = "";
    private string _agentColor = "#43b581";
    private string _agentProviderId = "";
    private string _agentModel = "";
    private string _agentPrompt = "";
    private string? _agentSaveError;
    private bool _isSavingAgent;
    private string _savedAgentName = "";
    private string _savedAgentColor = "#43b581";
    private string _savedAgentProviderId = "";
    private string _savedAgentModel = "";
    private string _savedAgentPrompt = "";
    private List<AgentMcpServerToolAvailabilityDto> _savedAgentMcpServerTools = [];
    private List<AgentMcpServerToolAvailabilityDto> _draftAgentMcpServerTools = [];
    private readonly HashSet<string> _expandedAgentMcpServerIds = [];
    private string? _hoveredMcpToolKey;
    private CancellationTokenSource? _mcpTooltipCts;
    private const int McpTooltipDelayMs = 400;

    private static readonly string[] AgentColors =
    [
        "#43b581", "#7289da", "#faa61a", "#e91e63",
        "#f04747", "#3498db", "#9b59b6", "#e67e22",
        "#1abc9c", "#2ecc71", "#e74c3c", "#8e44ad",
    ];

    // ---- Computed ----
    private List<Provider> EnabledProviders =>
        _settings.Providers
            .Where(p => p.Status == "enabled" && !string.IsNullOrEmpty(p.BackendId))
            .ToList();

    private Provider? AgentFormSelectedProvider =>
        string.IsNullOrEmpty(_agentProviderId)
            ? null
            : EnabledProviders.FirstOrDefault(p => p.BackendId == _agentProviderId);

    private List<string> AgentFormProviderModels =>
        AgentFormSelectedProvider?.SelectedModels ?? [];

    private List<McpServerConfigurationItem> AgentAssignableMcpServers
    {
        get
        {
            var selectedIds = _draftAgentMcpServerTools
                .Select(item => item.McpServerConfigurationId)
                .ToHashSet();

            return _mcpServers
                .Where(server => TryGetMcpServerConfigurationId(server, out var configId) && (server.IsEnabled || selectedIds.Contains(configId)))
                .OrderBy(server => server.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
    }

    private bool IsDraftAgent => _editingAgent == null;

    private bool CanSaveAgent =>
        !string.IsNullOrWhiteSpace(_agentName)
        && !_isSavingAgent
        && !string.IsNullOrEmpty(_agentProviderId)
        && (IsDraftAgent || HasAgentChanges);

    private bool HasAgentChanges =>
        IsDraftAgent
            || _agentName != _savedAgentName
            || _agentColor != _savedAgentColor
            || _agentProviderId != _savedAgentProviderId
            || _agentModel != _savedAgentModel
            || _agentPrompt != _savedAgentPrompt
            || SerializeAgentMcpServerTools(_draftAgentMcpServerTools) != SerializeAgentMcpServerTools(_savedAgentMcpServerTools);

    // ---- Lifecycle ----
    protected override async Task OnInitializedAsync()
    {
        // Load providers for the provider/model dropdowns
        var persisted = await SettingsService.LoadFromLocalStorageAsync();
        try
        {
            var apiProviders = await SettingsService.GetProvidersAsync();
            if (apiProviders.Count > 0)
                persisted.Providers = apiProviders;
        }
        catch { }
        _settings = persisted;

        // Load MCP servers for the tool attachment UI
        try
        {
            _mcpServers = await SettingsService.GetMcpServersAsync();
        }
        catch
        {
            _mcpServers = [];
        }

        // Load agents
        await AppState.LoadAgents(AgentService);
        _agents = AppState.Agents.ToList();
    }

    // ---- Agent CRUD ----
    private async Task HandleDeleteAgent(Guid agentId)
    {
        try
        {
            await AgentService.DeleteAgentAsync(agentId);
            await AppState.LoadAgents(AgentService, forceReload: true);
            _agents = AppState.Agents.ToList();
            StateHasChanged();
        }
        catch { }
    }

    private async Task HandleAgentsChanged()
    {
        await AppState.LoadAgents(AgentService, forceReload: true);
        _agents = AppState.Agents.ToList();
        StateHasChanged();
    }

    // ---- MCP server helpers ----
    private AgentMcpServerToolAvailabilityDto? GetDraftMcpServerAvailability(McpServerConfigurationItem server)
    {
        if (!TryGetMcpServerConfigurationId(server, out var configId))
            return null;

        return _draftAgentMcpServerTools
            .FirstOrDefault(item => item.McpServerConfigurationId == configId);
    }

    private bool IsAgentMcpServerEnabled(McpServerConfigurationItem server) =>
        GetDraftMcpServerAvailability(server) != null;

    private HashSet<string> GetAgentEnabledToolNames(McpServerConfigurationItem server) =>
        GetDraftMcpServerAvailability(server)?.EnabledToolNames.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? [];

    private List<McpServerToolItem> GetAgentVisibleTools(McpServerConfigurationItem server) =>
        server.Tools
            .Where(tool => tool.IsEnabled)
            .OrderBy(tool => tool.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private static bool TryGetMcpServerConfigurationId(McpServerConfigurationItem server, out Guid mcpServerConfigurationId) =>
        Guid.TryParse(server.BackendId, out mcpServerConfigurationId);

    private static List<AgentMcpServerToolAvailabilityDto> CloneAgentMcpServerTools(IEnumerable<AgentMcpServerToolAvailabilityDto> source) =>
        source
            .Select(item => new AgentMcpServerToolAvailabilityDto
            {
                McpServerConfigurationId = item.McpServerConfigurationId,
                EnabledToolNames = [..item.EnabledToolNames],
            })
            .ToList();

    private static string SerializeAgentMcpServerTools(IEnumerable<AgentMcpServerToolAvailabilityDto> source) =>
        string.Join(
            "|",
            source
                .OrderBy(item => item.McpServerConfigurationId)
                .Select(item => $"{item.McpServerConfigurationId}:{string.Join(",", item.EnabledToolNames.OrderBy(name => name, StringComparer.OrdinalIgnoreCase))}"));

    private static bool HaveSameEnabledToolNames(AgentMcpServerToolAvailabilityDto left, AgentMcpServerToolAvailabilityDto right) =>
        string.Equals(
            string.Join(",", left.EnabledToolNames.OrderBy(name => name, StringComparer.OrdinalIgnoreCase)),
            string.Join(",", right.EnabledToolNames.OrderBy(name => name, StringComparer.OrdinalIgnoreCase)),
            StringComparison.Ordinal);

    private void SetSavedAgentSnapshot(AgentDto? agent, string providerId)
    {
        if (agent == null)
        {
            _savedAgentName = "";
            _savedAgentColor = "#43b581";
            _savedAgentProviderId = "";
            _savedAgentModel = "";
            _savedAgentPrompt = "";
            _savedAgentMcpServerTools = [];
            return;
        }

        _savedAgentName = agent.Username;
        _savedAgentColor = agent.Color;
        _savedAgentProviderId = providerId;
        _savedAgentModel = agent.Model;
        _savedAgentPrompt = agent.Prompt;
        _savedAgentMcpServerTools = CloneAgentMcpServerTools(agent.AvailableMcpServerTools);
    }

    private (string Icon, string Color, string Label) GetAgentStatusBadge() =>
        IsDraftAgent
            ? (SvgFileEdit, "hsl(214, 60%, 55%)", "Draft")
            : HasAgentChanges
                ? (SvgPencilSmall, "hsl(40, 85%, 55%)", "Modified")
                : (SvgCircle, "hsl(145, 65%, 45%)", "Saved");

    private void OpenCreateAgent()
    {
        _agentsSubView = "form";
        _editingAgent = null;
        _agentName = "";
        _agentPrompt = "";
        _agentSaveError = null;
        var first = EnabledProviders.FirstOrDefault();
        if (first != null)
        {
            _agentProviderId = first.BackendId ?? "";
            var models = first.SelectedModels ?? [];
            _agentModel = (!string.IsNullOrEmpty(first.DefaultModel) && models.Contains(first.DefaultModel))
                ? first.DefaultModel
                : models.FirstOrDefault() ?? "";
        }
        else
        {
            _agentProviderId = "";
            _agentModel = "";
        }
        _agentColor = AgentColors[(_agents.Count) % AgentColors.Length];
        _draftAgentMcpServerTools = [];
        SetSavedAgentSnapshot(null, string.Empty);
    }

    private void OpenEditAgent(AgentDto agent)
    {
        _agentsSubView = "form";
        _editingAgent = agent;
        _agentName = agent.Username;
        _agentPrompt = agent.Prompt;
        _agentColor = agent.Color;
        _agentModel = agent.Model;
        _agentSaveError = null;
        var matching = EnabledProviders.FirstOrDefault(p => (p.SelectedModels ?? []).Contains(agent.Model));
        _agentProviderId = matching?.BackendId ?? EnabledProviders.FirstOrDefault()?.BackendId ?? "";
        if (string.IsNullOrEmpty(_agentProviderId))
            _agentModel = "";

        _draftAgentMcpServerTools = CloneAgentMcpServerTools(agent.AvailableMcpServerTools);
        SetSavedAgentSnapshot(agent, _agentProviderId);
    }

    private void BackToAgentList()
    {
        _agentsSubView = "list";
        _editingAgent = null;
        _agentSaveError = null;
        _draftAgentMcpServerTools = [];
    }

    private void OnAgentProviderChanged(ChangeEventArgs e)
    {
        _agentProviderId = e.Value?.ToString() ?? "";
        var provider = AgentFormSelectedProvider;
        var models = provider?.SelectedModels ?? [];
        if (!models.Contains(_agentModel))
        {
            _agentModel = (!string.IsNullOrEmpty(provider?.DefaultModel) && models.Contains(provider.DefaultModel))
                ? provider!.DefaultModel
                : models.FirstOrDefault() ?? "";
        }
    }

    private void ToggleAgentMcpToolsExpanded(string serverId)
    {
        if (!_expandedAgentMcpServerIds.Remove(serverId))
            _expandedAgentMcpServerIds.Add(serverId);
    }

    private async Task ShowMcpToolTooltip(string serverId, string toolName)
    {
        _mcpTooltipCts?.Cancel();
        _mcpTooltipCts = new CancellationTokenSource();
        var key = $"{serverId}|{toolName}";
        try
        {
            await Task.Delay(McpTooltipDelayMs, _mcpTooltipCts.Token);
            _hoveredMcpToolKey = key;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    private void HideMcpToolTooltip()
    {
        _mcpTooltipCts?.Cancel();
        _mcpTooltipCts = null;
        _hoveredMcpToolKey = null;
        StateHasChanged();
    }

    private static char GetMcpAvatarLetter(string name) =>
        string.IsNullOrWhiteSpace(name) ? '?' : char.ToUpperInvariant(name[0]);

    private static string GetMcpAvatarBackground(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "hsl(214, 20%, 28%)";
        var hue = (name[0] * 37) % 360;
        return $"hsl({hue}, 20%, 28%)";
    }

    private void ToggleAgentMcpServer(McpServerConfigurationItem server)
    {
        if (!TryGetMcpServerConfigurationId(server, out var configId))
            return;

        var current = _draftAgentMcpServerTools.FirstOrDefault(item => item.McpServerConfigurationId == configId);
        if (current == null)
        {
            _draftAgentMcpServerTools.Add(new AgentMcpServerToolAvailabilityDto
            {
                McpServerConfigurationId = configId,
                EnabledToolNames = [],
            });
            return;
        }

        _draftAgentMcpServerTools.Remove(current);
    }

    private void ToggleAgentMcpTool(McpServerConfigurationItem server, McpServerToolItem tool)
    {
        var availability = GetDraftMcpServerAvailability(server);
        if (availability == null)
            return;

        var enabledToolNames = availability.EnabledToolNames.ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (!enabledToolNames.Add(tool.Name))
            enabledToolNames.Remove(tool.Name);

        availability.EnabledToolNames = enabledToolNames
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task SaveAgent()
    {
        var name = _agentName.Trim();
        if (string.IsNullOrEmpty(name))
            return;

        if (!System.Text.RegularExpressions.Regex.IsMatch(name, @"^[a-z0-9]{2,30}$"))
        {
            _agentSaveError = "Username must contain only lowercase letters and numbers (2-30 characters).";
            return;
        }
        if (string.IsNullOrEmpty(_agentProviderId))
        {
            _agentSaveError = "Please select a provider";
            return;
        }
        if (!Guid.TryParse(_agentProviderId, out var providerGuid))
        {
            _agentSaveError = "Invalid provider";
            return;
        }

        _isSavingAgent = true;
        _agentSaveError = null;
        try
        {
            var prompt = string.IsNullOrWhiteSpace(_agentPrompt)
                ? $"You are {name}, a helpful AI assistant."
                : _agentPrompt.Trim();

            AgentDto? savedAgent = _editingAgent == null
                ? await AgentService.CreateAgentAsync(name, prompt, _agentModel, providerGuid, _agentColor, null)
                : await AgentService.UpdateAgentAsync(_editingAgent.Id, name, prompt, _agentModel, providerGuid, _agentColor, _editingAgent.Description);

            if (savedAgent == null)
            {
                _agentSaveError = _editingAgent == null
                    ? "Failed to create agent"
                    : "Failed to update agent";
                return;
            }

            _editingAgent = savedAgent;
            SetSavedAgentSnapshot(savedAgent, _agentProviderId);

            var mcpSaved = await SaveAgentMcpServersAsync(savedAgent.Id);
            await HandleAgentsChanged();

            if (!mcpSaved)
                return;

            _draftAgentMcpServerTools = CloneAgentMcpServerTools(_savedAgentMcpServerTools);
            BackToAgentList();
        }
        catch (Exception ex)
        {
            _agentSaveError = ex.Message;
        }
        finally
        {
            _isSavingAgent = false;
        }
    }

    private async Task<bool> SaveAgentMcpServersAsync(Guid agentId)
    {
        var savedByServerId = _savedAgentMcpServerTools.ToDictionary(item => item.McpServerConfigurationId);
        var draftByServerId = _draftAgentMcpServerTools.ToDictionary(item => item.McpServerConfigurationId);
        AgentDto? latestAgent = _editingAgent;

        foreach (var removedServerId in savedByServerId.Keys.Except(draftByServerId.Keys).OrderBy(id => id))
        {
            latestAgent = await AgentService.RemoveAvailableMcpServerAsync(agentId, removedServerId);
            if (latestAgent == null)
            {
                _agentSaveError = "Agent was saved, but removing an MCP server failed.";
                return false;
            }

            _editingAgent = latestAgent;
            SetSavedAgentSnapshot(latestAgent, _agentProviderId);
        }

        foreach (var draftBinding in draftByServerId.Values.OrderBy(item => item.McpServerConfigurationId))
        {
            if (savedByServerId.TryGetValue(draftBinding.McpServerConfigurationId, out var savedBinding)
                && HaveSameEnabledToolNames(savedBinding, draftBinding))
            {
                continue;
            }

            latestAgent = await AgentService.SetAvailableMcpServerAsync(
                agentId,
                draftBinding.McpServerConfigurationId,
                draftBinding.EnabledToolNames.OrderBy(name => name, StringComparer.OrdinalIgnoreCase));

            if (latestAgent == null)
            {
                _agentSaveError = "Agent was saved, but updating MCP tools failed.";
                return false;
            }

            _editingAgent = latestAgent;
            SetSavedAgentSnapshot(latestAgent, _agentProviderId);
        }

        return true;
    }

    private async Task ConfirmDeleteAgent()
    {
        if (_deleteAgentPending == null) return;
        _isDeletingAgent = true;
        try
        {
            await HandleDeleteAgent(_deleteAgentPending.Id);
            _deleteAgentPending = null;
        }
        finally
        {
            _isDeletingAgent = false;
        }
    }

    private static string GetAgentAvatar(AgentDto agent)
    {
        var u = agent.Username;
        if (string.IsNullOrWhiteSpace(u)) return "?";
        return u.Trim().ToUpperInvariant()[..1];
    }


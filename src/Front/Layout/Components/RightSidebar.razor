<div class="right-sidebar">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="right-sidebar-header">
            @Title
        </div>
    }
    @ChildContent
</div>

@code {
    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}

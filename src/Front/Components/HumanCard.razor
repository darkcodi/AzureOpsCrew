@namespace Front.Components

<div class="human-card">
    <div class="human-card-header-wrap">
        <div class="human-card-strip"></div>
        <div class="human-card-avatar-wrap">
            <div class="human-card-avatar">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
        </div>
        <div class="human-card-status">@Status</div>
    </div>
    <div class="human-card-body">
        <h3 class="human-card-name">@Name</h3>
        <p class="human-card-subtitle">Human</p>
        <p class="human-card-description">@Description</p>
        <div class="human-card-pills">
            <span class="human-card-pill">
                <span class="human-card-pill-dot human-card-pill-dot-online"></span>
                Human
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Name { get; set; } = "You";

    [Parameter]
    public string Status { get; set; } = "Online";

    [Parameter]
    public string Description { get; set; } = "Your profile and direct message threads.";
}

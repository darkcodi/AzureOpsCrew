@namespace Front.Components
<div class="agent-card">
    <div class="agent-card-header-wrap">
        <div class="agent-card-strip" style="background-color: @Agent.Color;"></div>
        <div class="agent-card-avatar-wrap">
            <div class="agent-card-avatar" style="background-color: @Agent.Color; color: #fff;">
                @GetAgentAvatar()
            </div>
        </div>
        <div class="agent-card-status @(AgentStatusDisplay.IsWaitingForApproval(Agent.Status) ? "agent-card-status-waiting" : string.Empty)">
            @AgentStatusDisplay.ToDisplayText(Agent.Status)
        </div>
    </div>
    <div class="agent-card-body">
        <h3 class="agent-card-name">@Agent.Username</h3>
        <p class="agent-card-id">@Agent.Id.ToString()</p>
        <p class="agent-card-bio">@GetBio()</p>
        <div class="agent-card-pills">
            <span class="agent-card-pill agent-card-pill-agent">
                <span class="agent-card-pill-dot"></span>
                Agent
            </span>
            <span class="agent-card-pill agent-card-pill-model">@GetModelDisplay()</span>
        </div>
        @if (!string.IsNullOrEmpty(Agent.ErrorMessage))
        {
            <div class="agent-card-error">
                <span class="agent-card-error-icon">⚠</span>
                <span class="agent-card-error-text">@Agent.ErrorMessage</span>
            </div>
        }
        @if (GetAgentMcpTools().Count > 0)
        {
            <div class="agent-card-mcp-section">
                <h4 class="agent-card-mcp-title">MCP Tools</h4>
                @foreach (var server in GetAgentMcpTools())
                {
                    <div class="agent-card-mcp-server">
                        <span class="agent-card-mcp-server-name">@server.Name</span>
                        <div class="agent-card-mcp-tools">
                            @foreach (var tool in server.EnabledTools)
                            {
                                <span class="agent-card-mcp-tool">@tool</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
@code {
    [Parameter, EditorRequired]
    public AgentDto Agent { get; set; } = null!;
    [CascadingParameter]
    public IEnumerable<McpServerConfigurationItem>? AllMcpServers { get; set; }
    private string GetAgentAvatar()
    {
        var u = Agent.Username;
        if (string.IsNullOrWhiteSpace(u)) return "?";
        var parts = u.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
        return u.Length >= 2 ? u[..2].ToUpperInvariant() : u.ToUpperInvariant();
    }
    private string GetBio()
    {
        var text = Agent.Prompt;
        if (string.IsNullOrEmpty(text))
            text = Agent.Description ?? string.Empty;
        if (text.Length <= 120) return text;
        return text[..120].TrimEnd() + "...";
    }
    private string GetModelDisplay()
    {
        var model = Agent.Model;
        if (string.IsNullOrEmpty(model)) return string.Empty;
        var lastSlash = model.LastIndexOf('/');
        return lastSlash >= 0 && lastSlash < model.Length - 1
            ? model[(lastSlash + 1)..]
            : model;
    }
    private List<(string Name, List<string> EnabledTools)> GetAgentMcpTools()
    {
        if (AllMcpServers == null) return [];
        var result = new List<(string Name, List<string> EnabledTools)>();
        foreach (var availability in Agent.AvailableMcpServerTools)
        {
            var server = AllMcpServers.FirstOrDefault(s =>
                Guid.TryParse(s.BackendId, out var serverId) &&
                serverId == availability.McpServerConfigurationId);
            if (server != null && availability.EnabledToolNames.Count > 0)
            {
                result.Add((server.Name, availability.EnabledToolNames));
            }
        }
        return result;
    }
}

@inject AppState AppState
@inject SettingsService SettingsService
@implements IDisposable

<div class="dm-right-pane">
    @if (AppState.SelectedDm == null)
    {
        <div class="dm-right-pane-placeholder">
            <p class="dm-right-pane-placeholder-text">Select a conversation to view profile.</p>
        </div>
    }
    else if (GetSelectedAgent() is { } agent)
    {
        <div class="dm-right-pane-content">
            <CascadingValue Value="@_mcpServers">
                <AgentCard Agent="agent" />
            </CascadingValue>
        </div>
    }
    else if (IsHumanDm(AppState.SelectedDm))
    {
        <div class="dm-right-pane-content">
            <HumanCard Name="@GetHumanDmName()" Status="Online" Description="@GetHumanDmDescription()" />
        </div>
    }
    else
    {
        <div class="dm-right-pane-placeholder">
            <p class="dm-right-pane-placeholder-text">Select a conversation to view profile.</p>
        </div>
    }
</div>

@code {
    private IDisposable? _subscription;
    private List<McpServerConfigurationItem> _mcpServers = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadMcpServersAsync();

        _subscription = AppState.SubscribeSelectedDm(OnStateChanged)
            .Combine(AppState.SubscribeDms(OnStateChanged))
            .Combine(AppState.SubscribeAgents(OnStateChanged));
    }

    private async Task LoadMcpServersAsync()
    {
        try
        {
            _mcpServers = await SettingsService.GetMcpServersAsync();
        }
        catch
        {
            _mcpServers = [];
        }
    }

    private void OnStateChanged() => InvokeAsync(() =>
    {
        StateHasChanged();
    });

    public void Dispose()
    {
        _subscription?.Dispose();
    }

    private AgentDto? GetSelectedAgent()
    {
        var dm = AppState.SelectedDm;
        if (dm == null) return null;
        var agentId = dm.Agent1Id ?? dm.Agent2Id;
        if (!agentId.HasValue) return null;
        return AppState.Agents.FirstOrDefault(a => a.Id == agentId.Value);
    }

    private static bool IsHumanDm(DmChannelDto dm)
    {
        return !dm.Agent1Id.HasValue && !dm.Agent2Id.HasValue;
    }

    private string GetHumanDmName()
    {
        var dm = AppState.SelectedDm;
        if (dm == null) return "You";
        var currentUserId = AppState.CurrentUser?.Id;
        if (dm.User1Id == currentUserId || dm.User2Id == currentUserId)
            return AppState.CurrentUser?.Username ?? "You";
        return "User";
    }

    private string GetHumanDmDescription()
    {
        var dm = AppState.SelectedDm;
        if (dm == null) return "Your profile and direct message threads.";
        var currentUserId = AppState.CurrentUser?.Id;
        if (dm.User1Id == currentUserId || dm.User2Id == currentUserId)
            return "Your profile and direct message threads.";
        return "Profile and direct message threads.";
    }

}

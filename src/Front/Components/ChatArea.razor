@inject IJSRuntime JS

<div class="chat-area">
    <div class="messages-container" @ref="_messagesContainer">
        @if (Messages.Count == 0 && ToolCalls.Count == 0 && Reasonings.Count == 0 && ApprovalRequests.Count == 0)
        {
            <div class="no-messages">
                <div class="welcome-icon">@EmptyIcon</div>
                <h3>@EmptyTitle</h3>
                <p>@EmptySubtitle</p>
            </div>
        }
        else
        {
            @foreach (var entry in GetTimeline())
            {
                if (entry.ToolCall is { } toolCall)
                {
                    if (string.Equals(toolCall.ToolName, "getMyIp", StringComparison.OrdinalIgnoreCase) && toolCall.IsFinished)
                    {
                        <IpInfoWidget ToolCall="toolCall" />
                    }
                    else
                    {
                        <ToolCallCard ToolCall="toolCall" />
                    }
                }
                else if (entry.ApprovalRequest is { } approval)
                {
                    <ApprovalRequestCard ApprovalRequest="approval" OnRespond="OnApprovalRespond" />
                }
                else if (entry.Reasoning is { } reasoning)
                {
                    <ReasoningCard Reasoning="reasoning" />
                }
                else if (entry.Message is { } msgGroup)
                {
                    <MessageBubble Message="@msgGroup.Message" IsGrouped="@msgGroup.IsGrouped" IsOwn="@msgGroup.IsOwn" OnAgentClick="OnAgentClick" />
                }
            }
        }
    </div>

    <div class="typing-bar">
        @if (TypingUsernames.Count > 0)
        {
            <TypingIndicator Usernames="TypingUsernames" />
            @if (IsAgentRunning && ShowStopButton)
            {
                <button class="stop-button" @onclick="OnStopAgent">
                    ⏹ Stop
                </button>
            }
        }
    </div>

    @if (ShowInput)
    {
        <div class="message-input-container">
            <div class="message-input-wrapper">
                <input type="text"
                       class="message-input"
                       placeholder="@Placeholder"
                       @bind="_messageText"
                       @bind:event="oninput"
                       @onkeypress="HandleKeyPress" />
                <button class="send-button" disabled="@string.IsNullOrEmpty(_messageText)" @onclick="SendMessage">
                    ➤
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<ChatMessageDto> Messages { get; set; } = [];
    [Parameter] public List<ToolCallDto> ToolCalls { get; set; } = [];
    [Parameter] public List<ReasoningDto> Reasonings { get; set; } = [];
    [Parameter] public List<ApprovalRequestDto> ApprovalRequests { get; set; } = [];
    [Parameter] public EventCallback<string> OnSendMessage { get; set; }
    [Parameter] public EventCallback<(string approvalId, bool approved)> OnApprovalRespond { get; set; }
    [Parameter] public Guid? CurrentUserId { get; set; }
    [Parameter] public bool ShowInput { get; set; } = true;
    [Parameter] public string Placeholder { get; set; } = "Type a message...";
    [Parameter] public string EmptyIcon { get; set; } = "💬";
    [Parameter] public string EmptyTitle { get; set; } = "No messages yet";
    [Parameter] public string EmptySubtitle { get; set; } = "Be the first to send a message!";
    [Parameter] public List<string> TypingUsernames { get; set; } = [];
    [Parameter] public bool IsAgentRunning { get; set; }
    [Parameter] public EventCallback OnStopAgent { get; set; }
    [Parameter] public bool ShowStopButton { get; set; } = true;
    [Parameter] public EventCallback<Guid?> OnAgentClick { get; set; }

    private ElementReference _messagesContainer;
    private string _messageText = string.Empty;
    private int _lastMessageCount;
    private int _lastToolCallCount;
    private int _lastReasoningCount;
    private int _lastApprovalCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || Messages.Count != _lastMessageCount || ToolCalls.Count != _lastToolCallCount || Reasonings.Count != _lastReasoningCount || ApprovalRequests.Count != _lastApprovalCount)
        {
            var hadNoContent = _lastMessageCount == 0 && _lastToolCallCount == 0 && _lastReasoningCount == 0 && _lastApprovalCount == 0;
            var hasContent = Messages.Count > 0 || ToolCalls.Count > 0 || Reasonings.Count > 0 || ApprovalRequests.Count > 0;
            _lastMessageCount = Messages.Count;
            _lastToolCallCount = ToolCalls.Count;
            _lastReasoningCount = Reasonings.Count;
            _lastApprovalCount = ApprovalRequests.Count;
            var forceScroll = firstRender || (hadNoContent && hasContent);
            await ScrollToBottomAsync(forceScroll: forceScroll);
        }
    }

    private record TimelineEntry(
        (ChatMessageDto Message, bool IsGrouped, bool IsOwn)? Message,
        ToolCallDto? ToolCall,
        ReasoningDto? Reasoning,
        ApprovalRequestDto? ApprovalRequest,
        DateTimeOffset Timestamp);

    private List<TimelineEntry> GetTimeline()
    {
        var entries = new List<TimelineEntry>();

        ChatMessageDto? previousMsg = null;
        foreach (var message in Messages)
        {
            var isOwn = message.UserId == CurrentUserId;
            var isGrouped = previousMsg != null
                            && message.AuthorName == previousMsg.AuthorName
                            && (message.PostedAt - previousMsg.PostedAt).TotalMinutes < 5;

            entries.Add(new TimelineEntry(
                (message, isGrouped, isOwn),
                null,
                null,
                null,
                new DateTimeOffset(message.PostedAt, TimeSpan.Zero)));
            previousMsg = message;
        }

        foreach (var toolCall in ToolCalls)
        {
            entries.Add(new TimelineEntry(null, toolCall, null, null, toolCall.Timestamp));
        }

        foreach (var reasoning in Reasonings)
        {
            entries.Add(new TimelineEntry(null, null, reasoning, null, reasoning.Timestamp));
        }

        foreach (var approvalRequest in ApprovalRequests)
        {
            entries.Add(new TimelineEntry(null, null, null, approvalRequest, approvalRequest.Timestamp));
        }

        entries.Sort((a, b) => a.Timestamp.CompareTo(b.Timestamp));
        return entries;
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_messageText))
            return;

        var text = _messageText;
        _messageText = string.Empty;
        await OnSendMessage.InvokeAsync(text);
    }

    private async Task ScrollToBottomAsync(bool forceScroll = false)
    {
        await JS.InvokeVoidAsync("scrollToBottom", _messagesContainer, forceScroll);
    }
}

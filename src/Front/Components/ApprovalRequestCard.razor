@namespace Front.Components
@using System.Text.Json

<div class="approval-card">
    <div class="approval-card-header">
        <div class="approval-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 9v4"/>
                <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636-2.87L13.637 3.59a1.914 1.914 0 0 0-3.274 0z"/>
                <path d="M12 17h.01"/>
            </svg>
        </div>
        <span class="approval-card-title">Approval Required</span>
        <span class="approval-card-tool-name">@ApprovalRequest.ToolName</span>
        <span class="approval-card-status @StatusClass">@StatusText</span>
    </div>

    @if (_isExpanded)
    {
        <div class="approval-card-body">
            @if (ApprovalRequest.Args != null)
            {
                <div class="approval-card-section">
                    <span class="approval-card-section-label">Arguments</span>
                    <pre class="approval-card-json">@FormatArgs()</pre>
                </div>
            }
        </div>
    }

    <div class="approval-card-footer">
        @if (ApprovalRequest.UserResponse is null)
        {
            <button class="approval-btn approve" @onclick="Approve" disabled="@_responding">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
                Approve
            </button>
            <button class="approval-btn reject" @onclick="Reject" disabled="@_responding">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
                Reject
            </button>
        }
        <button class="approval-btn toggle" @onclick="ToggleExpanded">
            @(_isExpanded ? "Hide Details" : "Show Details")
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ApprovalRequestDto ApprovalRequest { get; set; } = null!;

    [Parameter]
    public EventCallback<(string approvalId, bool approved)> OnRespond { get; set; }

    private bool _responding;
    private bool _isExpanded;

    private string StatusClass => ApprovalRequest.UserResponse switch
    {
        true => "approved",
        false => "rejected",
        null => "pending",
    };

    private string StatusText => ApprovalRequest.UserResponse switch
    {
        true => "Approved",
        false => "Rejected",
        null => "Pending",
    };

    private void ToggleExpanded() => _isExpanded = !_isExpanded;

    private async Task Approve()
    {
        _responding = true;
        await OnRespond.InvokeAsync((ApprovalRequest.ApprovalId, true));
    }

    private async Task Reject()
    {
        _responding = true;
        await OnRespond.InvokeAsync((ApprovalRequest.ApprovalId, false));
    }

    private string FormatArgs()
    {
        try
        {
            if (ApprovalRequest.Args is JsonElement jsonEl)
            {
                return JsonSerializer.Serialize(jsonEl, new JsonSerializerOptions { WriteIndented = true });
            }
            return ApprovalRequest.Args?.ToString() ?? "";
        }
        catch
        {
            return ApprovalRequest.Args?.ToString() ?? "";
        }
    }
}

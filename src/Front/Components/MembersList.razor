@inject AppState AppState
@implements IDisposable
@inject ChannelService ChannelService

<div class="members-list">
    <div class="members-list-header">
        <div class="members-search-wrap">
            <span class="members-search-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </span>
            <input type="search"
                   class="members-search-input"
                   placeholder="Search members..."
                   @bind="_searchQuery" />
        </div>
    </div>

    <div class="members-scroll">
        @if (AppState.SelectedChannel == null)
        {
            <div class="members-no-selection">Select a channel to see members</div>
        }
        else
        {
            var channelAgents = FilteredChannelAgents();
            var humans = FilteredHumans();
            var hasQuery = !string.IsNullOrWhiteSpace(_searchQuery);
            var noMatches = hasQuery && channelAgents.Count == 0 && humans.Count == 0;

            @if (noMatches)
            {
                <div class="members-empty">No members match your search.</div>
            }
            else
            {
                <div class="members-section-label">AI Agents</div>
                @if (channelAgents.Count == 0)
                {
                    <div class="members-empty">No agents in chat.</div>
                }
                else
                {
                    @foreach (var agent in channelAgents)
                    {
                        <div class="members-item" @onclick="() => OnAgentClick.InvokeAsync(agent)">
                            <div class="members-item-main">
                                <div class="members-avatar members-avatar-agent" style="background-color: @agent.Color; color: #fff;">
                                    @GetAgentInitials(agent.Username)
                                </div>
                                <div class="members-item-info">
                                    <span class="members-item-name">@agent.Username</span>
                                    <span class="members-item-status @(AgentStatusDisplay.IsWaitingForApproval(agent.Status) ? "members-item-status-waiting" : string.Empty)">@AgentStatusDisplay.ToDisplayText(agent.Status)</span>
                                </div>
                            </div>
                            <button type="button"
                                    class="members-item-remove-btn"
                                    title="Remove @agent.Username from channel"
                                    @onclick="() => OpenRemoveAgentDialog(agent)"
                                    @onclick:stopPropagation="true"
                                    aria-label="Remove @agent.Username from channel">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"/>
                                    <line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                            </button>
                        </div>
                    }
                }

                <button type="button" class="members-add-agents-btn" @onclick="OpenAddAgentsDialog">
                    <span class="members-add-agents-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                    </span>
                    <span>Add more agents</span>
                </button>

                <div class="members-section-label members-section-label-humans">Humans</div>
                @if (humans.Count == 0)
                {
                    <div class="members-item">
                        <div class="members-avatar members-avatar-human">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <div class="members-item-info">
                            <span class="members-item-name">You</span>
                            <span class="members-item-status members-item-status-online">
                                <span class="members-status-dot"></span> Online
                            </span>
                        </div>
                    </div>
                }
                @foreach (var user in humans)
                {
                    var displayName = user.Id == AppState.CurrentUser?.Id ? "You" : user.Username;
                    <div class="members-item" @onclick="() => MentionUser(user)">
                        <div class="members-avatar members-avatar-human">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <div class="members-item-info">
                            <span class="members-item-name">@displayName</span>
                            <span class="members-item-status members-item-status-online">
                                <span class="members-status-dot"></span> Online
                            </span>
                        </div>
                    </div>
                }
            }
        }
    </div>
</div>

@if (_addAgentsOpen && AppState.SelectedChannel != null)
{
    <div class="members-dialog-backdrop" @onclick="CloseAddAgentsDialog"></div>
    <div class="members-dialog" role="dialog" aria-modal="true" aria-labelledby="add-agents-title">
        <div class="members-dialog-header">
            <h2 id="add-agents-title" class="members-dialog-title">Add agents to chat</h2>
        </div>
        <div class="members-dialog-body">
            @{
                var notInChannel = AgentsNotInChannel();
            }
            @if (notInChannel.Count == 0)
            {
                <div class="members-dialog-empty">All agents are already in this chat.</div>
            }
            else
            {
                @foreach (var agent in notInChannel)
                {
                    <div class="members-dialog-row">
                        <div class="members-avatar members-avatar-agent" style="background-color: @agent.Color; color: #fff;">
                            @GetAgentInitials(agent.Username)
                        </div>
                        <span class="members-dialog-row-name">@agent.Username</span>
                        <button type="button"
                                class="members-dialog-add-btn"
                                disabled="@_addingAgentId.HasValue"
                                @onclick="() => AddAgentToChannel(agent.Id)">
                            @if (_addingAgentId == agent.Id)
                            {
                                <span class="members-dialog-add-spinner"></span>
                            }
                            else
                            {
                                <span>Add</span>
                            }
                        </button>
                    </div>
                }
            }
        </div>
    </div>
}

@if (_removeAgentPending != null)
{
    <div class="dialog-overlay" @onclick="() => _removeAgentPending = null">
        <div class="dialog-box" @onclick:stopPropagation="true" role="dialog" aria-labelledby="remove-agent-title" aria-describedby="remove-agent-desc">
            <div class="dialog-header">
                <h3 id="remove-agent-title" class="dialog-title">Remove from channel</h3>
                <div id="remove-agent-desc" class="dialog-description">
                    <p>Are you sure you want to remove <strong class="text-white">@_removeAgentPending.Username</strong> from this channel?</p>
                </div>
            </div>
            <div class="dialog-footer">
                <button type="button" class="btn btn-secondary" disabled="@_isRemovingAgent"
                        @onclick="() => _removeAgentPending = null">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger" disabled="@_isRemovingAgent"
                        @onclick="ConfirmRemoveAgent">
                    @(_isRemovingAgent ? "Removing..." : "Remove")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback<AgentDto> OnAgentClick { get; set; }

    private string _searchQuery = string.Empty;
    private bool _addAgentsOpen;
    private Guid? _addingAgentId;
    private AgentDto? _removeAgentPending;
    private bool _isRemovingAgent;

    private IDisposable? _appStateSubscription;

    protected override void OnInitialized()
    {
        _appStateSubscription = AppState.SubscribeSelectedChannel(OnStateChanged)
            .Combine(AppState.SubscribeCurrentUser(OnStateChanged))
            .Combine(AppState.SubscribeAgents(OnStateChanged));
    }

    private void OnStateChanged() => InvokeAsync(() =>
    {
        StateHasChanged();
    });

    public void Dispose()
    {
        _appStateSubscription?.Dispose();
    }

    private string GetAgentInitials(string username)
    {
        if (string.IsNullOrEmpty(username)) return "?";
        var parts = username.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
        return username.Length >= 2 ? username[..2].ToUpperInvariant() : username.ToUpperInvariant();
    }

    private List<AgentDto> FilteredChannelAgents()
    {
        var agentIds = AppState.SelectedChannel?.AgentIds.Select(id => Guid.TryParse(id, out var guid) ? guid : (Guid?)null)
            .Where(g => g.HasValue)
            .Select(g => g!.Value)
            .ToHashSet() ?? [];

        var agents = AppState.Agents.Where(a => agentIds.Contains(a.Id)).ToList();
        var q = _searchQuery?.Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(q)) return agents;
        return agents.Where(a => (a.Username ?? "").ToLowerInvariant().Contains(q)).ToList();
    }

    private List<UserDto> FilteredHumans()
    {
        var currentName = AppState.CurrentUser?.Username ?? "You";
        var users = new List<UserDto>();
        if (AppState.CurrentUser != null)
            users.Add(AppState.CurrentUser);
        users.AddRange(GetOnlineUsers().Where(u => u.Id != AppState.CurrentUser?.Id));
        var q = _searchQuery?.Trim().ToLowerInvariant();
        if (string.IsNullOrEmpty(q)) return users;
        return users.Where(u =>
        {
            var name = u.Id == AppState.CurrentUser?.Id ? currentName : u.Username;
            return (name ?? "").ToLowerInvariant().Contains(q);
        }).ToList();
    }

    private List<UserDto> GetOnlineUsers() => []; // TODO: Implement online users tracking

    private List<AgentDto> AgentsNotInChannel()
    {
        if (AppState.SelectedChannel == null) return [];
        var channelIdSet = AppState.SelectedChannel.AgentIds
            .Select(s => Guid.TryParse(s, out var g) ? g : (Guid?)null)
            .Where(g => g.HasValue)
            .Select(g => g!.Value)
            .ToHashSet();
        return AppState.Agents.Where(a => !channelIdSet.Contains(a.Id)).OrderBy(a => a.Username).ToList();
    }

    private void OpenAddAgentsDialog() => _addAgentsOpen = true;

    private void CloseAddAgentsDialog() => _addAgentsOpen = false;

    private void OpenRemoveAgentDialog(AgentDto agent) => _removeAgentPending = agent;

    private async Task ConfirmRemoveAgent()
    {
        if (_removeAgentPending == null || AppState.SelectedChannel == null) return;
        _isRemovingAgent = true;
        StateHasChanged();
        try
        {
            var ok = await ChannelService.RemoveAgentFromChannelAsync(AppState.SelectedChannel.Id, _removeAgentPending.Id);
            if (ok)
                await AppState.LoadChannels(ChannelService, forceReload: true);
            _removeAgentPending = null;
        }
        finally
        {
            _isRemovingAgent = false;
            StateHasChanged();
        }
    }

    private async Task AddAgentToChannel(Guid agentId)
    {
        if (AppState.SelectedChannel == null) return;
        _addingAgentId = agentId;
        StateHasChanged();
        try
        {
            var ok = await ChannelService.AddAgentToChannelAsync(AppState.SelectedChannel.Id, agentId);
            if (ok)
                await AppState.LoadChannels(ChannelService, forceReload: true);
        }
        finally
        {
            _addingAgentId = null;
            StateHasChanged();
        }
    }


    private void MentionUser(UserDto user) { /* TODO */ }
}

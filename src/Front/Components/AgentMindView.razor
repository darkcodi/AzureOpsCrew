@namespace Front.Components
@inject IJSRuntime JS

<div class="agent-mind-overlay" @onclick="OnClose">
    <div class="agent-mind-content" @onclick:stopPropagation="true">
        <div class="agent-mind-header">
            <div class="agent-mind-header-info">
                <div class="agent-mind-avatar" style="background-color: @Agent.Color; color: #fff;">
                    @GetAgentInitials(Agent.Username)
                </div>
                <h2 class="agent-mind-title">@Agent.Username's Mind</h2>
            </div>
            <button type="button" class="agent-mind-close-btn" @onclick="OnClose" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <div class="agent-mind-body" @ref="_bodyContainer">
            @if (IsLoading)
            {
                <div class="agent-mind-loading">
                    <div class="agent-mind-spinner"></div>
                    <span>Loading agent mind...</span>
                </div>
            }
            else if (ToolCalls.Count == 0 && Reasonings.Count == 0)
            {
                <div class="agent-mind-empty">
                    No tool calls or reasoning yet for this agent.
                </div>
            }
            else
            {
                @foreach (var entry in GetTimeline())
                {
                    if (entry.ToolCall is { } toolCall)
                    {
                        <ToolCallCard ToolCall="toolCall" />
                    }
                    else if (entry.Reasoning is { } reasoning)
                    {
                        <ReasoningCard Reasoning="reasoning" />
                    }
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public AgentDto Agent { get; set; } = null!;

    [Parameter]
    public List<ToolCallDto> ToolCalls { get; set; } = [];

    [Parameter]
    public List<ReasoningDto> Reasonings { get; set; } = [];

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private ElementReference _bodyContainer;
    private int _lastCount;

    private record TimelineEntry(ToolCallDto? ToolCall, ReasoningDto? Reasoning, DateTimeOffset Timestamp);

    private List<TimelineEntry> GetTimeline()
    {
        var entries = new List<TimelineEntry>(ToolCalls.Count + Reasonings.Count);

        foreach (var tc in ToolCalls)
            entries.Add(new TimelineEntry(tc, null, tc.Timestamp));

        foreach (var r in Reasonings)
            entries.Add(new TimelineEntry(null, r, r.Timestamp));

        entries.Sort((a, b) => a.Timestamp.CompareTo(b.Timestamp));
        return entries;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var currentCount = ToolCalls.Count + Reasonings.Count;
        if (firstRender || currentCount != _lastCount)
        {
            _lastCount = currentCount;
            await JS.InvokeVoidAsync("scrollToBottom", _bodyContainer, firstRender);
        }
    }

    private string GetAgentInitials(string username)
    {
        if (string.IsNullOrEmpty(username)) return "?";
        var parts = username.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
        return username.Length >= 2 ? username[..2].ToUpperInvariant() : username.ToUpperInvariant();
    }
}

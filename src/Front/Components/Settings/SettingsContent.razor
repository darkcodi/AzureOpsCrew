    [Parameter] public HashSet<string> ModifiedMcpServerIds { get; set; } = [];
    [Parameter] public string? SelectedMcpServerId { get; set; }
    [Parameter] public EventCallback<string> OnSelectMcpServer { get; set; }
    [Parameter] public EventCallback<List<McpServerConfigurationItem>> OnMcpServersChange { get; set; }
    [Parameter] public EventCallback<McpServerAuthEditorState?> OnSaveCurrentMcpServer { get; set; }
    [Parameter] public EventCallback OnResetCurrentMcpServer { get; set; }
    [Parameter] public EventCallback OnRemoveCurrentMcpServer { get; set; }
    [Parameter] public EventCallback OnSyncMcpServer { get; set; }
    [Parameter] public EventCallback OnToggleSelectedMcpServerEnabled { get; set; }
    [Parameter] public EventCallback<string> OnToggleSelectedMcpServerTool { get; set; }
    [Parameter] public bool IsSavingMcpServer { get; set; }
    [Parameter] public bool IsSyncingMcpServer { get; set; }
    [Parameter] public bool IsUpdatingMcpServerTool { get; set; }
    [Parameter] public string? UpdatingMcpServerToolName { get; set; }
    [Parameter] public int McpServerAuthResetKey { get; set; }
    [Parameter] public string? McpServerError { get; set; }
    [Parameter] public IReadOnlyList<AgentDto>? Agents { get; set; }
    [Parameter] public EventCallback<AgentDto> OnEditAgent { get; set; }
    [Parameter] public EventCallback OnCreateAgent { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteAgent { get; set; }
    [Parameter] public EventCallback OnAgentsChanged { get; set; }

    private string _searchQuery = "";
    private bool _showApiKey;
    private bool _addProviderDialogOpen;
    private Provider? _removeProviderPending;
    private bool _isRemovingProvider;
    private AgentDto? _deleteAgentPending;
    private bool _isDeletingAgent;
    private string _customModelInput = "";

    // ---- Agents list vs form view ----
    private string _agentsSubView = "list"; // "list" | "form"
    private AgentDto? _editingAgent;
    private string _agentName = "";
    private string _agentColor = "#43b581";
    private string _agentProviderId = "";
    private string _agentModel = "";
    private string _agentPrompt = "";
    private string? _agentSaveError;
    private bool _isSavingAgent;
    private string? _agentMcpError;
    private bool _isUpdatingAgentMcpServer;
    private string? _updatingAgentMcpServerId;
    private bool _isUpdatingAgentMcpTool;
    private string? _updatingAgentMcpToolServerId;
    private string? _updatingAgentMcpToolName;

    private static readonly string[] AgentColors =
    [
        "#43b581", "#7289da", "#faa61a", "#e91e63",
        "#f04747", "#3498db", "#9b59b6", "#e67e22",
        "#1abc9c", "#2ecc71", "#e74c3c", "#8e44ad",
    ];

    private Provider? SelectedProvider => Settings.Providers.FirstOrDefault(p => p.Id == SelectedProviderId);

    private List<Provider> FilteredProviders =>
        Settings.Providers
            .Where(p => p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.DateCreated != null && DateTime.TryParse(p.DateCreated, out var d) ? d.Ticks : long.MaxValue)
            .ToList();

    private void UpdateProvider(string id, Action<Provider> updater)
    {
        var provider = Settings.Providers.FirstOrDefault(p => p.Id == id);
        if (provider == null) return;
        updater(provider);
        OnSettingsChange.InvokeAsync(Settings);
    }

    private void CloseAddProviderDialog() => _addProviderDialogOpen = false;

    private void AddProvider(KnownProvider kp)
    {
        var existingIds = Settings.Providers.Select(p => p.Id).ToHashSet();
        var newId = existingIds.Contains(kp.Id) ? $"{kp.Id}-{DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}" : kp.Id;
        Settings.Providers.Add(new Provider
        {
            Id = newId,
            Name = kp.Name,
            ProviderType = kp.ProviderType,
            Status = "draft",
            ApiKey = "",
            BaseUrl = kp.BaseUrl,
            DefaultModel = "",
            Timeout = kp.Timeout,
            RateLimit = kp.RateLimit,
        });
        OnSelectProvider.InvokeAsync(newId);
        OnSettingsChange.InvokeAsync(Settings);
        _addProviderDialogOpen = false;
    }

    private async Task ConfirmRemoveProvider()
    {
        if (_removeProviderPending == null) return;
        _isRemovingProvider = true;
        try
        {
            await OnRemoveProvider.InvokeAsync(_removeProviderPending.Id);
            _removeProviderPending = null;
        }
        finally
        {
            _isRemovingProvider = false;
        }
    }

    private async Task ConfirmDeleteAgent()
    {
        if (_deleteAgentPending == null) return;
        _isDeletingAgent = true;
        try
        {
            await OnDeleteAgent.InvokeAsync(_deleteAgentPending.Id);
            _deleteAgentPending = null;
        }
        finally
        {
            _isDeletingAgent = false;
        }
    }

    private async Task HandleRemoveClick()
    {
        if (SelectedProvider == null) return;
        if (string.IsNullOrEmpty(SelectedProvider.BackendId))
        {
            await OnRemoveProvider.InvokeAsync(SelectedProvider.Id);
        }
        else
        {
            _removeProviderPending = SelectedProvider;
        }
    }

    private void AddCustomModel()
    {
        var name = _customModelInput.Trim();
        if (string.IsNullOrEmpty(name) || SelectedProvider == null) return;
        var current = SelectedProvider.SelectedModels ?? [];
        if (current.Contains(name)) return;
        SelectedProvider.SelectedModels = [..current, name];
        OnSettingsChange.InvokeAsync(Settings);
        _customModelInput = "";
    }


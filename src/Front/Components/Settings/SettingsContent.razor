                                @foreach (var m in AgentFormProviderModels)
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="agent-form-field">
                        <label for="agent-prompt" class="agent-form-label">System Prompt</label>
                        <textarea id="agent-prompt" class="agent-form-textarea" rows="4" placeholder="Describe the agent's role and behavior..."
                                  @bind="_agentPrompt" @bind:event="oninput"></textarea>
                    </div>
                    <div class="agent-form-field agent-mcp-field">
                        <div class="agent-mcp-header">
                            <div>
                                <label class="agent-form-label">MCP Servers</label>
                                <p class="agent-mcp-subtitle">Attach globally enabled MCP servers to this agent and choose which synced tools it can use.</p>
                            </div>
                        </div>

                        @if (_editingAgent == null)
                        {
                            <div class="agent-form-message">Create the agent first, then return here to enable MCP servers and tools.</div>
                        }
                        else if (AgentAssignableMcpServers.Count == 0)
                        {
                            <div class="agent-form-message">No saved and enabled MCP servers are available yet. Configure them in the MCP Servers section first.</div>
                        }
                        else
                        {
                            <div class="agent-mcp-servers">
                                @foreach (var server in AgentAssignableMcpServers)
                                {
                                    var isServerEnabledForAgent = IsAgentMcpServerEnabled(server);
                                    var enabledToolNames = GetAgentEnabledToolNames(server);
                                    var tools = GetAgentVisibleTools(server);
                                    var canToggleServer = !_isSavingAgent && !_isUpdatingAgentMcpServer && !_isUpdatingAgentMcpTool && (server.IsEnabled || isServerEnabledForAgent);

                                    <div class="agent-mcp-server @(isServerEnabledForAgent ? "selected" : "")">
                                        <div class="agent-mcp-server-header">
                                            <div class="agent-mcp-server-meta">
                                                <div class="agent-mcp-server-title-row">
                                                    <span class="agent-mcp-server-name">@server.Name</span>
                                                    @if (!server.IsEnabled)
                                                    {
                                                        <span class="agent-mcp-server-state">Disabled in MCP Servers</span>
                                                    }
                                                </div>
                                                <span class="agent-mcp-server-url">@server.Url</span>
                                                <span class="agent-mcp-server-note">@tools.Count available tool(s)</span>
                                            </div>
                                            <button type="button" role="switch" aria-checked="@isServerEnabledForAgent"
                                                    class="toggle-switch @(isServerEnabledForAgent ? "on" : "")"
                                                    disabled="@(!canToggleServer)"
                                                    @onclick="() => ToggleAgentMcpServerAsync(server)">
                                                <span class="toggle-knob"></span>
                                            </button>
                                        </div>

                                        @if (isServerEnabledForAgent)
                                        {
                                            <div class="agent-mcp-tools">
                                                @if (tools.Count == 0)
                                                {
                                                    <div class="agent-mcp-empty">No globally enabled tools are available on this MCP server yet.</div>
                                                }
                                                else
                                                {
                                                    @foreach (var tool in tools)
                                                    {
                                                        var isUpdatingCurrentTool = _isUpdatingAgentMcpTool
                                                            && string.Equals(_updatingAgentMcpToolServerId, server.Id, StringComparison.Ordinal)
                                                            && string.Equals(_updatingAgentMcpToolName, tool.Name, StringComparison.Ordinal);
                                                        var isToolEnabledForAgent = enabledToolNames.Contains(tool.Name);
                                                        var canToggleTool = !_isSavingAgent && !_isUpdatingAgentMcpServer && !_isUpdatingAgentMcpTool;

                                                        <div class="agent-mcp-tool @(isToolEnabledForAgent ? string.Empty : "off")">
                                                            <div class="agent-mcp-tool-content">
                                                                <span class="agent-mcp-tool-name">@tool.Name</span>
                                                                <div class="agent-mcp-tool-badges">
                                                                    <span class="agent-mcp-tool-badge">Input: @(string.IsNullOrWhiteSpace(tool.InputSchemaJson) ? "No" : "Yes")</span>
                                                                    <span class="agent-mcp-tool-badge">Output: @(string.IsNullOrWhiteSpace(tool.OutputSchemaJson) ? "No" : "Yes")</span>
                                                                </div>
                                                                @if (!string.IsNullOrWhiteSpace(tool.Description))
                                                                {
                                                                    <span class="agent-mcp-tool-description">@tool.Description</span>
                                                                }
                                                            </div>
                                                            <button type="button" class="agent-mcp-tool-action"
                                                                    disabled="@(!canToggleTool)"
                                                                    @onclick="() => ToggleAgentMcpToolAsync(server, tool)">
                                                                @(isUpdatingCurrentTool ? "Updating..." : isToolEnabledForAgent ? "Deactivate" : "Activate")
                                                            </button>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-primary agent-form-save"
                            disabled="@(string.IsNullOrWhiteSpace(_agentName) || _isSavingAgent || string.IsNullOrEmpty(_agentProviderId))"
                            @onclick="SaveAgent">
                        <span class="agent-form-save-icon">@((MarkupString)SvgSave)</span>
                        <span>@(_isSavingAgent ? "Saving..." : _editingAgent == null ? "Create Agent" : "Save Changes")</span>
                    </button>
                    @if (!string.IsNullOrEmpty(_agentMcpError))
                    {
                        <div class="agent-form-error">@_agentMcpError</div>
                    }
                    @if (!string.IsNullOrEmpty(_agentSaveError))
                    {
                        <div class="agent-form-error">@_agentSaveError</div>
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderRouting() => __builder =>

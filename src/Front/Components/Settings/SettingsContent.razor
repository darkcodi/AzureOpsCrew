                                <input type="text" class="custom-model-input" @bind="_customModelInput" @bind:event="oninput"
                                       placeholder="Type custom model name..."
                                       @onkeydown="HandleCustomModelKeyDown" />
                                <button type="button" class="input-action-btn" @onclick="AddCustomModel" title="Add custom model">
                                    @((MarkupString)SvgPlus)
                                </button>
                            </span>
                        </div>
                    </div>

                    @* Default model *@
                    <div class="form-field">
                        <label class="form-label">Default model (optional)</label>
                        <select class="form-select"
                                value="@(sp.SelectedModels?.Contains(sp.DefaultModel) == true ? sp.DefaultModel : "")"
                                @onchange="e => UpdateProvider(sp.Id, p => p.DefaultModel = e.Value?.ToString() ?? string.Empty)">
                            <option value="">None</option>
                            @foreach (var m in sp.SelectedModels ?? [])
                            {
                                <option value="@m">@m</option>
                            }
                        </select>
                        <p class="form-description">Choose from your selected models above.</p>
                    </div>

                    @* Enabled toggle *@
                    <div class="form-field">
                        <label class="form-label">Enabled</label>
                        <button type="button" role="switch" aria-checked="@(sp.Status != "disabled")"
                                class="toggle-switch @(sp.Status != "disabled" ? "on" : "")"
                                @onclick="() => ToggleProviderEnabled(sp)">
                            <span class="toggle-knob"></span>
                        </button>
                        <p class="form-description">When off, this provider is disabled and won't be used.</p>
                    </div>

                    @if (!string.IsNullOrEmpty(SaveError))
                    {
                        <p class="save-error">@SaveError</p>
                    }

                    <div class="action-buttons">
                        <button type="button" class="btn btn-primary"
                                disabled="@(IsSaving || SelectedProviderId == null || !(ModifiedProviderIds.Contains(SelectedProviderId!) || string.IsNullOrEmpty(sp.BackendId)))"
                                @onclick="OnSaveCurrentProvider">
                            @(IsSaving ? "Saving...." : "Save")
                        </button>
                        <button type="button" class="btn btn-secondary" disabled="@(IsSaving || IsTesting)"
                                @onclick="OnTestProvider">
                            @(IsTesting ? "Testing...." : "Test")
                        </button>
                        <button type="button" class="btn btn-danger" disabled="@IsSaving"
                                @onclick="HandleRemoveClick">
                            Remove
                        </button>
                    </div>
                </div>
            }
        </div>
    };

    private RenderFragment RenderAgents() => __builder =>
    {

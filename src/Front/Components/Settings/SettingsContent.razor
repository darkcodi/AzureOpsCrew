            <div class="form-field">
                <label class="form-label">Fallback enabled</label>
                <button type="button" role="switch" class="toggle-switch @(Settings.Routing.FallbackEnabled ? "on" : "")" disabled>
                    <span class="toggle-knob"></span>
                </button>
                <p class="form-description">Automatically try another provider if the primary fails.</p>
            </div>

            <div class="form-field">
                <label class="form-label">Max retries</label>
                <input type="number" class="form-input" value="@Settings.Routing.MaxRetries" min="0" max="10" disabled />
                <p class="form-description">Maximum number of retry attempts before failing.</p>
            </div>
        </div>
    };

    private RenderFragment RenderAdvanced() => __builder =>
    {
        <div class="section-header">
            <h2 class="section-title">Advanced</h2>
            <p class="section-description">Low-level configuration options. Change these only if you know what you're doing.</p>
        </div>

        <div class="form-field">
            <label class="form-label">Developer mode</label>
            <button type="button" role="switch"
                    class="toggle-switch @(Settings.Advanced.DebugMode ? "on" : "")"
                    @onclick="() => { Settings.Advanced.DebugMode = !Settings.Advanced.DebugMode; OnSettingsChange.InvokeAsync(Settings); }">
                <span class="toggle-knob"></span>
            </button>
            <p class="form-description">Enable developer overlays and non-released features.</p>
        </div>
    };

    private RenderFragment RenderAccount() => __builder =>
    {
        var initial = string.IsNullOrWhiteSpace(Settings.Account.Username)
            ? "U"
            : Settings.Account.Username.Trim().ToUpper()[..1];

        <div class="section-header">
            <h2 class="section-title">Account</h2>
            <p class="section-description">Manage your account settings and preferences.</p>
        </div>

        <div class="account-card">
            <div class="account-avatar">@initial</div>
            <div>
                <div class="account-name">@(string.IsNullOrWhiteSpace(Settings.Account.Username) ? "User" : Settings.Account.Username)</div>
                <div class="account-subtitle">Local account</div>
            </div>
        </div>

        <div class="form-field" style="margin-top: 24px;">
            <label class="form-label">Username</label>
            <input type="text" class="form-input" value="@Settings.Account.Username" placeholder="Your username"
                   @oninput="e => { Settings.Account.Username = e.Value?.ToString() ?? string.Empty; OnSettingsChange.InvokeAsync(Settings); }" />
        </div>
    };

    private RenderFragment RenderAppearance() => __builder =>
    {
        <div class="disabled-section">
            <div class="section-header">
                <h2 class="section-title">Appearance</h2>
                <p class="section-description">Customize the look and feel of the application.</p>
            </div>

            <div class="form-field">
                <label class="form-label">Theme</label>
                <select class="form-select" value="@Settings.Appearance.Theme" disabled>
                    <option value="dark">Dark</option>
                    <option value="light">Light</option>
                    <option value="system">System</option>
                </select>
            </div>

            <div class="form-field">
                <label class="form-label">Font size</label>
                <select class="form-select" value="@Settings.Appearance.FontSize" disabled>
                    <option value="small">Small (13px)</option>
                    <option value="medium">Medium (15px)</option>
                    <option value="large">Large (18px)</option>
                </select>
            </div>

            <div class="form-field">
                <label class="form-label">Compact mode</label>
                <button type="button" role="switch" class="toggle-switch @(Settings.Appearance.CompactMode ? "on" : "")" disabled>
                    <span class="toggle-knob"></span>
                </button>
                <p class="form-description">Reduce spacing between messages and UI elements.</p>
            </div>
        </div>
    };

    private RenderFragment RenderNotifications() => __builder =>
    {
        <div class="disabled-section">
            <div class="section-header">
                <h2 class="section-title">Notifications</h2>
                <p class="section-description">Configure how and when you receive notifications.</p>
            </div>

            <div class="form-field">
                <label class="form-label">Desktop notifications</label>
                <button type="button" role="switch" class="toggle-switch @(Settings.Notifications.DesktopNotifications ? "on" : "")" disabled>
                    <span class="toggle-knob"></span>
                </button>
                <p class="form-description">Show system notifications for new messages.</p>
            </div>

            <div class="form-field">
                <label class="form-label">Sound</label>
                <button type="button" role="switch" class="toggle-switch @(Settings.Notifications.SoundEnabled ? "on" : "")" disabled>
                    <span class="toggle-knob"></span>
                </button>
                <p class="form-description">Play a sound when notifications arrive.</p>
            </div>

            <div class="form-field">
                <label class="form-label">Mention notifications</label>
                <button type="button" role="switch" class="toggle-switch @(Settings.Notifications.MentionNotifications ? "on" : "")" disabled>
                    <span class="toggle-knob"></span>
                </button>
                <p class="form-description">Notify when you are mentioned by an agent or in a channel.</p>
            </div>
        </div>
    };

    private void ToggleProviderEnabled(Provider p)
    {
        var isEnabled = p.Status != "disabled";
        if (isEnabled)
        {
            p.Status = "disabled";
        }
        else
        {
            p.Status = string.IsNullOrEmpty(p.BackendId) ? "draft" : "enabled";
        }
        OnSettingsChange.InvokeAsync(Settings);
    }

    private void HandleCustomModelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddCustomModel();
    }

    private static string GetAgentAvatar(AgentDto agent)
    {
        var u = agent.Username;
        if (string.IsNullOrWhiteSpace(u)) return "?";
        return u.Trim().ToUpperInvariant()[..1];
    }
}

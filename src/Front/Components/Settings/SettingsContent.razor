@inject AgentService AgentService

<div class="settings-content">
    <div class="settings-content-scroll">
        <div class="settings-content-inner">
            @switch (ActiveSection)
            {
                case SettingsSection.Providers:
                    @RenderProviders()
                    break;
                case SettingsSection.McpServers:
                    <McpServersSettingsSection McpServers="McpServers"
                                               ModifiedMcpServerIds="ModifiedMcpServerIds"
                                               SelectedMcpServerId="@SelectedMcpServerId"
                                               OnSelectMcpServer="OnSelectMcpServer"
                                               OnMcpServersChange="OnMcpServersChange"
                                               OnSaveCurrentMcpServer="OnSaveCurrentMcpServer"
                                               OnResetCurrentMcpServer="OnResetCurrentMcpServer"
                                               OnRemoveCurrentMcpServer="OnRemoveCurrentMcpServer"
                                               OnSyncMcpServer="OnSyncMcpServer"
                                               OnToggleSelectedMcpServerEnabled="OnToggleSelectedMcpServerEnabled"
                                               OnToggleSelectedMcpServerTool="OnToggleSelectedMcpServerTool"
                                               IsSavingMcpServer="IsSavingMcpServer"
                                               IsSyncingMcpServer="IsSyncingMcpServer"
                                               IsUpdatingMcpServerTool="IsUpdatingMcpServerTool"
                                               UpdatingMcpServerToolName="@UpdatingMcpServerToolName"
                                               McpServerAuthResetKey="McpServerAuthResetKey"
                                               McpServerError="@McpServerError" />
                    break;
                case SettingsSection.Agents:
                    @RenderAgents()
                    break;
                case SettingsSection.Routing:
                    @RenderRouting()
                    break;
                case SettingsSection.Advanced:
                    @RenderAdvanced()
                    break;
                case SettingsSection.Account:
                    @RenderAccount()
                    break;
                case SettingsSection.Appearance:
                    @RenderAppearance()
                    break;
                case SettingsSection.Notifications:
                    @RenderNotifications()
                    break;
            }

            @if (ActiveSection is SettingsSection.Routing or SettingsSection.Appearance or SettingsSection.Notifications)
            {
                <div class="wip-banner">
                    This settings page is still in development (WIP).
                </div>
            }
        </div>
    </div>
</div>

@* ---- Add Provider Dialog ---- *@
@if (_addProviderDialogOpen)
{
    <div class="dialog-overlay" @onclick="CloseAddProviderDialog">
        <div class="dialog-box" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h3 class="dialog-title">Add provider</h3>
                <p class="dialog-description">Choose a provider to add to your settings.</p>
            </div>
            <div class="dialog-body">
                @foreach (var kp in KnownProviders)
                {
                    <button type="button" class="provider-option" @onclick="() => AddProvider(kp)">
                        <span class="provider-option-icon">@((MarkupString)kp.SvgIcon)</span>
                        <span>@kp.Name</span>
                    </button>
                }
            </div>
        </div>
    </div>
}

@* ---- Remove Provider Dialog ---- *@
@if (_removeProviderPending != null)
{
    <div class="dialog-overlay" @onclick="() => _removeProviderPending = null">
        <div class="dialog-box" @onclick:stopPropagation="true">
            <div class="dialog-header">
                <h3 class="dialog-title">Remove Provider</h3>
                <div class="dialog-description">
                    <p>Are you sure you want to remove <strong class="text-white">@_removeProviderPending.Name</strong>?</p>
                    <p>This cannot be undone.</p>
                </div>
            </div>
            <div class="dialog-footer">
                <button type="button" class="btn btn-secondary" disabled="@_isRemovingProvider"
                        @onclick="() => _removeProviderPending = null">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger" disabled="@_isRemovingProvider"
                        @onclick="ConfirmRemoveProvider">
                    @(_isRemovingProvider ? "Removing...." : "Remove")
                </button>
            </div>
        </div>
    </div>
}

@* ---- Delete Agent Dialog ---- *@
@if (_deleteAgentPending != null)
{
    <div class="dialog-overlay" @onclick="() => _deleteAgentPending = null">
        <div class="dialog-box" @onclick:stopPropagation="true" role="dialog" aria-labelledby="delete-agent-title" aria-describedby="delete-agent-desc">
            <div class="dialog-header">
                <h3 id="delete-agent-title" class="dialog-title">Delete Agent</h3>
                <div id="delete-agent-desc" class="dialog-description">
                    <p>Are you sure you want to delete <strong class="text-white">@_deleteAgentPending.Username</strong>?</p>
                    <p>This cannot be undone.</p>
                </div>
            </div>
            <div class="dialog-footer">
                <button type="button" class="btn btn-secondary" disabled="@_isDeletingAgent"
                        @onclick="() => _deleteAgentPending = null">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger" disabled="@_isDeletingAgent"
                        @onclick="ConfirmDeleteAgent">
                    @(_isDeletingAgent ? "Deleting...." : "Delete Agent")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public SettingsSection ActiveSection { get; set; }
    [Parameter] public SettingsState Settings { get; set; } = new();
    [Parameter] public SettingsState SavedSettings { get; set; } = new();
    [Parameter] public HashSet<string> ModifiedProviderIds { get; set; } = [];
    [Parameter] public string? SelectedProviderId { get; set; }
    [Parameter] public EventCallback<string> OnSelectProvider { get; set; }
    [Parameter] public EventCallback<SettingsState> OnSettingsChange { get; set; }
    [Parameter] public EventCallback OnSaveCurrentProvider { get; set; }
    [Parameter] public EventCallback OnTestProvider { get; set; }
    [Parameter] public EventCallback<string> OnRemoveProvider { get; set; }
    [Parameter] public EventCallback<string> OnToggleSelectedModel { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public bool IsTesting { get; set; }
    [Parameter] public string? SaveError { get; set; }

    private record KnownProvider(string Id, string Name, string ProviderType, string BaseUrl, int Timeout, int RateLimit, string SvgIcon);

    private static readonly KnownProvider[] KnownProviders =
    [
        new("anthropic", "Anthropic", "Anthropic", "https://api.anthropic.com/v1", 30, 60, SvgBrain),
        new("azure-foundry", "Azure Foundry", "AzureFoundry", "https://your-resource.openai.azure.com", 30, 60, SvgCloud),
        new("ollama", "Ollama", "Ollama (Local)", "http://localhost:11434", 120, 0, SvgServer),
        new("openai", "OpenAI", "OpenAI", "https://api.openai.com/v1", 30, 60, SvgSparkles),
        new("openrouter", "OpenRouter", "OpenRouter", "https://openrouter.ai/api/v1", 30, 60, SvgGlobe),
    ];

    // ---- Status badge helper ----
    private (string Icon, string Color, string Label) GetStatusBadge(Provider p)
    {
        if (ModifiedProviderIds.Contains(p.Id))
            return (SvgPencil, "hsl(40, 85%, 55%)", "Modified");
        if (string.IsNullOrEmpty(p.BackendId))
            return (SvgFileEdit, "hsl(214, 60%, 55%)", "Draft");
        return p.Status switch
        {
            "enabled" => (SvgCircle, "hsl(145, 65%, 45%)", "Enabled"),
            "disabled" => (SvgXCircle, "hsl(214, 5%, 55%)", "Disabled"),
            _ => (SvgFileEdit, "hsl(214, 60%, 55%)", "Draft"),
        };
    }

    // ---- Provider description helpers ----
    private static (string Desc, string Url, string UrlLabel)? GetProviderDescription(string? providerType) =>
        providerType switch
        {
            "OpenRouter" => ("OpenRouter is a unified API for LLMs. Use one API key to access many models with better prices and uptime.", "https://openrouter.ai/", "openrouter.ai"),
            "OpenAI" => ("OpenAI provides GPT models and the ChatGPT API. Create an account and use the API for completions, embeddings, and more.", "https://platform.openai.com/", "platform.openai.com"),
            "Anthropic" => ("Anthropic builds Claude, a family of AI assistants. Use the API for chat, long context, and tool use.", "https://www.anthropic.com/", "anthropic.com"),
            "Ollama (Local)" => ("Ollama runs LLMs locally on your machine. No API key or cloud account needed\u2014install and pull models to get started.", "https://ollama.com/", "ollama.com"),
            "AzureFoundry" => ("Azure AI Foundry (formerly Azure AI Studio) provides access to OpenAI models and other AI services hosted on Azure.", "https://ai.azure.com/", "ai.azure.com"),
            _ => null,
        };

    private static (string Text, string? Url, string? LinkText) GetApiKeyDescription(string? providerType) =>
        providerType switch
        {
            "OpenRouter" => ("Get your API key at ", "https://openrouter.ai/settings/keys", "openrouter.ai/settings/keys"),
            "OpenAI" => ("Get your API key at ", "https://platform.openai.com/api-keys", "platform.openai.com/api-keys"),
            "Anthropic" => ("Get your API key at ", "https://console.anthropic.com", "console.anthropic.com"),
            "Ollama (Local)" => ("No API key needed for local use.", null, null),
            "AzureFoundry" => ("Get your API key from your Azure OpenAI resource in the Azure Portal.", null, null),
            _ => ("", null, null),
        };

    private static string GetApiKeyLabel(Provider p)
    {
        var pt = p.ProviderType ?? p.Name;
        if (pt == "Ollama (Local)") return "API Key (optional)";
        if (!string.IsNullOrEmpty(p.BackendId) && p.HasApiKey == true) return "New API Key (leave blank to keep existing)";
        return "API Key";
    }

    private List<Provider> EnabledProviders =>
        Settings.Providers
            .Where(p => p.Status == "enabled" && !string.IsNullOrEmpty(p.BackendId))
            .ToList();

    private Provider? AgentFormSelectedProvider =>
        string.IsNullOrEmpty(_agentProviderId)
            ? null
            : EnabledProviders.FirstOrDefault(p => p.BackendId == _agentProviderId);

    private List<string> AgentFormProviderModels =>
        AgentFormSelectedProvider?.SelectedModels ?? [];

    private List<McpServerConfigurationItem> AgentAssignableMcpServers
    {
        get
        {
            var selectedIds = _editingAgent?.AvailableMcpServerTools
                .Select(item => item.McpServerConfigurationId)
                .ToHashSet() ?? [];

            return McpServers
                .Where(server => TryGetMcpServerConfigurationId(server, out var configId) && (server.IsEnabled || selectedIds.Contains(configId)))
                .OrderBy(server => server.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
    }

    private AgentMcpServerToolAvailabilityDto? GetAgentMcpServerAvailability(McpServerConfigurationItem server)
    {
        if (_editingAgent == null || !TryGetMcpServerConfigurationId(server, out var configId))
            return null;

        return _editingAgent.AvailableMcpServerTools
            .FirstOrDefault(item => item.McpServerConfigurationId == configId);
    }

    private bool IsAgentMcpServerEnabled(McpServerConfigurationItem server) =>
        GetAgentMcpServerAvailability(server) != null;

    private HashSet<string> GetAgentEnabledToolNames(McpServerConfigurationItem server) =>
        GetAgentMcpServerAvailability(server)?.EnabledToolNames.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? [];

    private List<McpServerToolItem> GetAgentVisibleTools(McpServerConfigurationItem server) =>
        server.Tools
            .Where(tool => tool.IsEnabled)
            .OrderBy(tool => tool.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private static bool TryGetMcpServerConfigurationId(McpServerConfigurationItem server, out Guid mcpServerConfigurationId) =>
        Guid.TryParse(server.BackendId, out mcpServerConfigurationId);

    private void ApplyUpdatedEditingAgent(AgentDto updatedAgent)
    {
        if (_editingAgent?.Id == updatedAgent.Id)
            _editingAgent = updatedAgent;
    }

    private void ResetAgentMcpState()
    {
        _agentMcpError = null;
        _isUpdatingAgentMcpServer = false;
        _updatingAgentMcpServerId = null;
        _isUpdatingAgentMcpTool = false;
        _updatingAgentMcpToolServerId = null;
        _updatingAgentMcpToolName = null;
    }

    private async Task ToggleAgentMcpServerAsync(McpServerConfigurationItem server)
    {
        if (_editingAgent == null)
        {
            _agentMcpError = "Save the agent first before assigning MCP servers.";
            return;
        }

        if (!TryGetMcpServerConfigurationId(server, out var mcpServerConfigurationId))
            return;

        var isEnabledForAgent = IsAgentMcpServerEnabled(server);
        if (!server.IsEnabled && !isEnabledForAgent)
            return;

        _agentMcpError = null;
        _isUpdatingAgentMcpServer = true;
        _updatingAgentMcpServerId = server.Id;

        try
        {
            AgentDto? updatedAgent = isEnabledForAgent
                ? await AgentService.RemoveAvailableMcpServerAsync(_editingAgent.Id, mcpServerConfigurationId)
                : await AgentService.SetAvailableMcpServerAsync(_editingAgent.Id, mcpServerConfigurationId, []);

            if (updatedAgent == null)
            {
                _agentMcpError = isEnabledForAgent
                    ? "Failed to remove MCP server from the agent."
                    : "Failed to add MCP server to the agent.";
                return;
            }

            ApplyUpdatedEditingAgent(updatedAgent);
            await OnAgentsChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _agentMcpError = ex.Message;
        }
        finally
        {
            _isUpdatingAgentMcpServer = false;
            _updatingAgentMcpServerId = null;
        }
    }

    private async Task ToggleAgentMcpToolAsync(McpServerConfigurationItem server, McpServerToolItem tool)
    {
        if (_editingAgent == null)
        {
            _agentMcpError = "Save the agent first before choosing MCP tools.";
            return;
        }

        if (!TryGetMcpServerConfigurationId(server, out var mcpServerConfigurationId))
            return;

        var availability = GetAgentMcpServerAvailability(server);
        if (availability == null)
        {
            _agentMcpError = "Enable the MCP server for this agent first.";
            return;
        }

        var enabledToolNames = availability.EnabledToolNames
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!enabledToolNames.Add(tool.Name))
            enabledToolNames.Remove(tool.Name);

        _agentMcpError = null;
        _isUpdatingAgentMcpTool = true;
        _updatingAgentMcpToolServerId = server.Id;
        _updatingAgentMcpToolName = tool.Name;

        try
        {
            var updatedAgent = await AgentService.SetAvailableMcpServerAsync(
                _editingAgent.Id,
                mcpServerConfigurationId,
                enabledToolNames.OrderBy(name => name, StringComparer.OrdinalIgnoreCase));

            if (updatedAgent == null)
            {
                _agentMcpError = "Failed to update MCP tool availability.";
                return;
            }

            ApplyUpdatedEditingAgent(updatedAgent);
            await OnAgentsChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _agentMcpError = ex.Message;
        }
        finally
        {
            _isUpdatingAgentMcpTool = false;
            _updatingAgentMcpToolServerId = null;
            _updatingAgentMcpToolName = null;
        }
    }

    private void OpenCreateAgent()
    {
        _agentsSubView = "form";
        _editingAgent = null;
        _agentName = "";
        _agentPrompt = "";
        _agentSaveError = null;
        ResetAgentMcpState();
        var first = EnabledProviders.FirstOrDefault();
        if (first != null)
        {
            _agentProviderId = first.BackendId ?? "";
            var models = first.SelectedModels ?? [];
            _agentModel = (!string.IsNullOrEmpty(first.DefaultModel) && models.Contains(first.DefaultModel))
                ? first.DefaultModel
                : models.FirstOrDefault() ?? "";
        }
        else
        {
            _agentProviderId = "";
            _agentModel = "";
        }
        _agentColor = AgentColors[(Agents?.Count ?? 0) % AgentColors.Length];
    }

    private void OpenEditAgent(AgentDto agent)
    {
        _agentsSubView = "form";
        _editingAgent = agent;
        _agentName = agent.Username;
        _agentPrompt = agent.Prompt;
        _agentColor = agent.Color;
        _agentModel = agent.Model;
        _agentSaveError = null;
        ResetAgentMcpState();
        var matching = EnabledProviders.FirstOrDefault(p => (p.SelectedModels ?? []).Contains(agent.Model));
        _agentProviderId = matching?.BackendId ?? EnabledProviders.FirstOrDefault()?.BackendId ?? "";
        if (string.IsNullOrEmpty(_agentProviderId))
            _agentModel = "";
    }

    private void BackToAgentList()
    {
        _agentsSubView = "list";
        _editingAgent = null;
        _agentSaveError = null;
        ResetAgentMcpState();
    }

    private void OnAgentProviderChanged(ChangeEventArgs e)
    {
        _agentProviderId = e.Value?.ToString() ?? "";
        var provider = AgentFormSelectedProvider;
        var models = provider?.SelectedModels ?? [];
        if (!models.Contains(_agentModel))
        {
            _agentModel = (!string.IsNullOrEmpty(provider?.DefaultModel) && models.Contains(provider.DefaultModel))
                ? provider!.DefaultModel
                : models.FirstOrDefault() ?? "";
        }
    }

    private async Task SaveAgent()
    {
        var name = _agentName.Trim();
        if (string.IsNullOrEmpty(name))
            return;

        // Validate username format
        if (!System.Text.RegularExpressions.Regex.IsMatch(name, @"^[a-z0-9]{2,30}$"))
        {
            _agentSaveError = "Username must contain only lowercase letters and numbers (2-30 characters).";
            return;
        }
        if (string.IsNullOrEmpty(_agentProviderId))
        {
            _agentSaveError = "Please select a provider";
            return;
        }
        if (!Guid.TryParse(_agentProviderId, out var providerGuid))
        {
            _agentSaveError = "Invalid provider";
            return;
        }

        _isSavingAgent = true;
        _agentSaveError = null;
        try
        {
            var prompt = string.IsNullOrWhiteSpace(_agentPrompt)
                ? $"You are {name}, a helpful AI assistant."
                : _agentPrompt.Trim();

            if (_editingAgent == null)
            {
                var created = await AgentService.CreateAgentAsync(name, prompt, _agentModel, providerGuid, _agentColor, null);
                if (created != null)
                {
                    await OnAgentsChanged.InvokeAsync();
                    BackToAgentList();
                }
                else
                    _agentSaveError = "Failed to create agent";
            }
            else
            {
                var updated = await AgentService.UpdateAgentAsync(_editingAgent.Id, name, prompt, _agentModel, providerGuid, _agentColor, _editingAgent.Description);
                if (updated != null)
                {
                    await OnAgentsChanged.InvokeAsync();
                    BackToAgentList();
                }
                else
                    _agentSaveError = "Failed to update agent";
            }
        }
        catch (Exception ex)
        {
            _agentSaveError = ex.Message;
        }
        finally
        {
            _isSavingAgent = false;
        }
    }


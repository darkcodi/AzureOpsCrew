<div class="info-panel">
    <div class="info-panel-scroll">
        <div class="info-panel-inner">
            @switch (ActiveSection)
            {
                case SettingsSection.Providers when SelectedProvider != null:
                    @RenderProviderInfo()
                    break;
                case SettingsSection.Providers:
                    @RenderGeneralProviderInfo()
                    break;
                case SettingsSection.McpServers:
                    <McpServersInfoPanel SelectedMcpServer="SelectedMcpServer" />
                    break;
                case SettingsSection.Routing:
                    @RenderRoutingInfo()
                    break;
                case SettingsSection.Advanced:
                    @RenderAdvancedInfo()
                    break;
                case SettingsSection.Account:
                    @RenderAccountInfo()
                    break;
                case SettingsSection.Appearance:
                    @RenderAppearanceInfo()
                    break;
                case SettingsSection.Notifications:
                    @RenderNotificationsInfo()
                    break;
                case SettingsSection.Agents:
                    @RenderAgentsInfo()
                    break;
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public SettingsSection ActiveSection { get; set; }
    [Parameter] public Provider? SelectedProvider { get; set; }
    [Parameter] public List<string> SelectedModels { get; set; } = [];
    [Parameter] public EventCallback<string> OnToggleSelectedModel { get; set; }
    [Parameter] public ProviderTestResult? ProviderTestResult { get; set; }
    [Parameter] public McpServerConfigurationItem? SelectedMcpServer { get; set; }

    private bool _modelsExpanded;
    private string _modelsSearchQuery = "";

    private const string SvgSearch =
        """<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>""";
    private const string SvgChevronDown =
        """<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>""";
    private const string SvgChevronUp =
        """<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>""";

    private static string FormatCheckedAt(string? checkedAt)
    {
        if (string.IsNullOrEmpty(checkedAt)) return "\u2014";
        if (!DateTime.TryParse(checkedAt, out var d)) return checkedAt;
        var diff = DateTime.UtcNow - d.ToUniversalTime();
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours} h ago";
        return d.ToLocalTime().ToString("g");
    }

    private RenderFragment RenderProviderInfo() => __builder =>
    {
        var hasResult = ProviderTestResult != null;
        var statusColor = hasResult && ProviderTestResult!.Success
            ? "hsl(145, 65%, 45%)"
            : hasResult
                ? "hsl(0, 70%, 55%)"
                : "hsl(214, 5%, 55%)";

        @* ── Test Result ── *@
        <div class="info-section">
            <h4 class="info-section-title">Test result</h4>
            <div class="test-result-card">
                @if (!hasResult)
                {
                    <p class="info-muted">Press "Test" to check connectivity and see latency, last check, and quota.</p>
                }
                else
                {
                    <div class="test-result-header">
                        <span class="status-dot" style="background-color: @statusColor;"></span>
                        <span class="test-provider-name">@SelectedProvider!.Name</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row-label">Latency</span>
                        <span class="info-row-value">@(ProviderTestResult!.LatencyMs != null ? $"{ProviderTestResult.LatencyMs} ms" : "\u2014")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row-label">Last check</span>
                        <span class="info-row-value">@FormatCheckedAt(ProviderTestResult!.CheckedAt)</span>
                    </div>
                    <div class="info-row">
                        <span class="info-row-label">Quota</span>
                        <span class="info-row-value" style="color: @(ProviderTestResult!.Success ? "hsl(145, 65%, 45%)" : "hsl(0, 70%, 55%)")">
                            @(ProviderTestResult!.Quota ?? "\u2014")
                        </span>
                    </div>
                }
            </div>
        </div>

        @* ── Available Models ── *@
        <div class="info-section">
            <h4 class="info-section-title">Available models</h4>
            <div class="models-list">
                @if (ProviderTestResult?.AvailableModels == null || ProviderTestResult.AvailableModels.Count == 0)
                {
                    <p class="info-muted">Press "Test" to see available models.</p>
                }
                else
                {
                    var all = ProviderTestResult.AvailableModels.OrderBy(m => m.Id, StringComparer.OrdinalIgnoreCase).ToList();
                    var selectedSet = SelectedModels.ToHashSet();
                    var selectedSorted = all.Where(m => selectedSet.Contains(m.Id)).ToList();
                    var unselected = all.Where(m => !selectedSet.Contains(m.Id)).ToList();
                    var models = selectedSorted.Concat(unselected).ToList();

                    var query = _modelsSearchQuery.Trim().ToLowerInvariant();
                    var filtered = string.IsNullOrEmpty(query)
                        ? models
                        : models.Where(m => m.Id.Contains(query, StringComparison.OrdinalIgnoreCase) || m.Name.Contains(query, StringComparison.OrdinalIgnoreCase)).ToList();
                    const int initialCount = 5;
                    var showAll = _modelsExpanded || filtered.Count <= initialCount;
                    var visible = showAll ? filtered : filtered.Take(initialCount).ToList();
                    var hiddenCount = filtered.Count - initialCount;

                    <div class="models-search">
                        <span class="models-search-icon">@((MarkupString)SvgSearch)</span>
                        <input type="search" class="models-search-input" placeholder="Search models..."
                               @bind="_modelsSearchQuery" @bind:event="oninput" />
                    </div>

                    @if (filtered.Count == 0)
                    {
                        <p class="info-muted">
                            @(string.IsNullOrEmpty(query) ? "No models available." : $"No models match \"{_modelsSearchQuery.Trim()}\".")
                        </p>
                    }
                    else
                    {
                        @foreach (var m in visible)
                        {
                            var isDefault = !string.IsNullOrEmpty(SelectedProvider?.DefaultModel) &&
                                            (m.Id == SelectedProvider.DefaultModel || m.Name == SelectedProvider.DefaultModel);
                            var isSelected = selectedSet.Contains(m.Id);
                            var showDefaultStyle = isDefault && isSelected;
                            var borderStyle = showDefaultStyle
                                ? "2px solid hsl(142, 58%, 45%)"
                                : isSelected
                                    ? "1px solid hsl(235, 86%, 65%)"
                                    : "1px solid transparent";

                            <div class="model-item @(showDefaultStyle ? "default-model" : "")"
                                 style="border: @borderStyle; @(showDefaultStyle ? "font-weight:600;" : "")"
                                 title="@m.Name"
                                 @onclick="() => OnToggleSelectedModel.InvokeAsync(m.Id)">
                                @m.Id
                            </div>
                        }

                        @if (!showAll && hiddenCount > 0)
                        {
                            <button type="button" class="show-more-btn" @onclick="() => _modelsExpanded = true">
                                <span>@((MarkupString)SvgChevronDown)</span>
                                Show @hiddenCount more
                            </button>
                        }
                        @if (showAll && filtered.Count > initialCount)
                        {
                            <button type="button" class="show-more-btn" @onclick="() => _modelsExpanded = false">
                                <span>@((MarkupString)SvgChevronUp)</span>
                                Show less
                            </button>
                        }
                    }
                }
            </div>
        </div>

        @* ── Notes ── *@
        <div class="info-section">
            <h4 class="info-section-title">Notes</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Keys are encrypted at rest.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Use profiles (dev/prod) to switch endpoints.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Agents can override the default provider/model.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderGeneralProviderInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Providers</h4>
            <p class="info-muted-body">Select a provider from the list to view its test result, available models, and configuration details.</p>
        </div>
        <div class="info-section">
            <h4 class="info-section-title">Quick tips</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Click a provider to see its details.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Use "Test" to verify connectivity.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>The default provider is used for new agents.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderRoutingInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Routing strategies</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span><strong>Priority:</strong> Always tries the default provider first.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span><strong>Round Robin:</strong> Distributes load evenly across providers.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span><strong>Cost Optimized:</strong> Prefers cheaper models when possible.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span><strong>Latency Optimized:</strong> Routes to the fastest responding provider.</span></li>
            </ul>
        </div>
        <div class="info-section">
            <h4 class="info-section-title">Notes</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Fallback kicks in when the primary provider fails or times out.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Per-agent routing overrides take precedence over global settings.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderAdvancedInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Caution</h4>
            <p class="info-warning">Changing advanced settings may affect application stability. Only modify these if you understand the implications.</p>
        </div>
        <div class="info-section">
            <h4 class="info-section-title">Notes</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Developer mode enables overlays and non-released features.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderAccountInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Account</h4>
            <p class="info-muted-body">Your account is stored locally. All settings and data persist in the local database.</p>
        </div>
    };

    private RenderFragment RenderAppearanceInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Theme</h4>
            <p class="info-muted-body">The dark theme is optimized for extended use. Light and system themes are available for accessibility.</p>
        </div>
        <div class="info-section">
            <h4 class="info-section-title">Notes</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Theme changes apply instantly.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Compact mode reduces vertical spacing for denser layouts.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderNotificationsInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Notifications</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Desktop notifications require browser permission.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Sounds play only when the tab is in the background.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Mention notifications are triggered by &#64;-mentions in channels.</span></li>
            </ul>
        </div>
    };

    private RenderFragment RenderAgentsInfo() => __builder =>
    {
        <div class="info-section">
            <h4 class="info-section-title">Agents</h4>
            <ul class="note-list">
                <li class="note-bullet"><span class="bullet">&bull;</span><span>Each agent can have its own provider and model.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>System prompts define the agent's personality and capabilities.</span></li>
                <li class="note-bullet"><span class="bullet">&bull;</span><span>MCP connections enable external tool integration.</span></li>
            </ul>
        </div>
    };
}

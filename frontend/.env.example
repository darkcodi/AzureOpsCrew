# Backend API endpoint for direct API calls (e.g. agent creation).
# Default when unset: http://localhost:5000
# If backend runs via docker-compose from /backend, use: http://localhost:42100
BACKEND_API_URL=

# Keycloak OIDC configuration (used by Next.js auth callback routes)
# Example authority: https://aus.aoc-app.com/realms/master
KEYCLOAK_AUTHORITY=
KEYCLOAK_CLIENT_ID=
PUBLIC_APP_URL=
KEYCLOAK_CALLBACK_URL=
# Optional for confidential clients (leave empty for public PKCE client)
KEYCLOAK_CLIENT_SECRET=
# Optional override when running behind a reverse proxy / custom frontend domain
KEYCLOAK_CALLBACK_URL=

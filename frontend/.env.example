# Azure OpenAI (CopilotKit chat popup).
# Key from Azure Portal → Cognitive Services resource → Keys and Endpoint
OPENAI_API_KEY=

# Deployment name in Azure OpenAI Studio (e.g. gpt-4o, gpt-4)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Backend AG-UI endpoint (used by Next.js API route to proxy CopilotKit → backend).
# Default when unset: http://localhost:5000/agui
BACKEND_AGUI_URL=

# Backend API endpoint for direct API calls (e.g. agent creation).
# Default when unset: http://localhost:5000
BACKEND_API_URL=

# Server-side backend URL used by Next.js API routes (runs on the server).
# Default when unset: http://localhost:5000
# Docker-compose: http://api:80 (internal Docker network)
BACKEND_API_URL=

# Client-side backend URL used by SignalR (runs in the browser).
# Default when unset: http://localhost:5000
# Docker-compose: http://localhost:45000 (host-exposed API port)
# NOTE: NEXT_PUBLIC_* vars are inlined at build time — runtime overrides won't work.
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:5000
